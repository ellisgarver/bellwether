---
import "../styles/global.css";
import { loadIndex } from "@lib/data";

interface Props {
  title: string;
  active?: "home" | "narratives" | "emerging" | "guide" | "data" | "research";
  wide?: boolean;
}
const { title, active, wide = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = (p: string) => (base.replace(/\/$/, "") + p) || "/";
const asOf = loadIndex().generated_at?.slice(0, 10) ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · bellwether</title>
    <meta
      name="description"
      content="bellwether tracks how macro-finance narratives form, spread, and fade across sixteen years of institutional and academic writing, mapped and charted against the press and the markets."
    />
    <link rel="icon" type="image/svg+xml" href={href("/favicon.svg")} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="bellwether" />
    <meta property="og:title" content={`${title} · bellwether`} />
    <meta
      property="og:description"
      content="how macro narratives rise and fade: sixteen years of institutional macro-finance writing, mapped and charted."
    />
    <meta name="twitter:card" content="summary" />
  </head>
  <body data-base={base.replace(/\/$/, "")}>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={href("/")}>
          <img class="brand-icon" src={href("/favicon.svg")} alt="" width="22" height="22" />
          <span class="wordmark">bell<span class="mk">wether</span></span>
        </a>
        <nav class="nav">
          <a href={href("/narratives")} class={active === "narratives" ? "active" : ""}>narratives</a>
          <a href={href("/emerging")} class={active === "emerging" ? "active" : ""}>emerging</a>
          <a href={href("/guide")} class={active === "guide" ? "active" : ""}>guide</a>
          <a href={href("/data")} class={active === "data" ? "active" : ""}>data</a>
          <a href={href("/research")} class={active === "research" ? "active" : ""}>research</a>
          {asOf && <span class="asof">as of {asOf}</span>}
        </nav>
      </div>
    </header>
    <main>
      {wide ? <slot /> : <div class="wrap"><slot /></div>}
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <span>bellwether · by ellis garver</span>
        <span>
          {asOf && <>data as of {asOf} · </>}
          <a href="https://github.com/ellisgarver/bellwether" target="_blank" rel="noopener">github</a>
          · <a href="mailto:ehgarver@uchicago.edu">ehgarver@uchicago.edu</a>
        </span>
      </div>
    </footer>

    <script>
      // a refresh should always land at the top with the entrance animations
      // replayed, not restore the previous scroll position mid-page.
      if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      window.scrollTo(0, 0);

      // the header is flat at the top of the page and picks up its blur +
      // hairline only once content actually scrolls beneath it.
      const hdr = document.querySelector(".site-header");
      const onScroll = () => hdr?.classList.toggle("scrolled", window.scrollY > 8);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      // scroll-reveal: fade-and-lift elements tagged .reveal as they enter view
      const els = document.querySelectorAll(".reveal");
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("in"));
      }
    </script>

    <style>
      .brand { display: inline-flex; align-items: center; gap: 0.55rem; }
      .brand-icon { display: block; border-radius: 5px; }
    </style>
  </body>
</html>
