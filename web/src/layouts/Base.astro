---
import "../styles/global.css";

interface Props {
  title: string;
  active?: "home" | "narratives" | "emerging" | "guide" | "data" | "research";
  wide?: boolean;
}
const { title, active, wide = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = (p: string) => (base.replace(/\/$/, "") + p) || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · macro narrative dynamics</title>
    <meta
      name="description"
      content="how macro-finance narratives spread through institutional and academic writing — read as epidemic-style life-cycles."
    />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={href("/")}>
          <svg class="virus" viewBox="0 0 40 40" aria-hidden="true">
            <g class="spikes">
              <line x1="30" y1="20" x2="34.5" y2="20" /><circle cx="34.8" cy="20" r="1.7" />
              <line x1="27.07" y1="27.07" x2="30.25" y2="30.25" /><circle cx="30.5" cy="30.5" r="1.7" />
              <line x1="20" y1="30" x2="20" y2="34.5" /><circle cx="20" cy="34.8" r="1.7" />
              <line x1="12.93" y1="27.07" x2="9.75" y2="30.25" /><circle cx="9.5" cy="30.5" r="1.7" />
              <line x1="10" y1="20" x2="5.5" y2="20" /><circle cx="5.2" cy="20" r="1.7" />
              <line x1="12.93" y1="12.93" x2="9.75" y2="9.75" /><circle cx="9.5" cy="9.5" r="1.7" />
              <line x1="20" y1="10" x2="20" y2="5.5" /><circle cx="20" cy="5.2" r="1.7" />
              <line x1="27.07" y1="12.93" x2="30.25" y2="9.75" /><circle cx="30.5" cy="9.5" r="1.7" />
            </g>
            <circle class="body" cx="20" cy="20" r="9.5" />
            <g class="face">
              <circle class="eye" cx="16.1" cy="17.6" r="3" />
              <circle class="eye" cx="23.8" cy="17.4" r="2.5" />
              <circle class="pupil" cx="17" cy="18.5" r="1.2" />
              <circle class="pupil" cx="23.3" cy="16.5" r="1" />
              <path class="mouth" d="M15.7 23.1 Q20 24.2 24.3 23.1 Q24.1 27 20 27 Q15.9 27 15.7 23.1 Z" />
              <ellipse class="tongue" cx="21.7" cy="26" rx="1.85" ry="1.3" />
              <path class="tooth" d="M17.7 23.4 L20.7 23.4 L20.7 24.9 Q19.2 25.4 17.7 24.9 Z" />
            </g>
          </svg>
          <span class="wordmark">macro <span class="mk">narrative</span> dynamics</span>
        </a>
        <nav class="nav">
          <a href={href("/narratives")} class={active === "narratives" ? "active" : ""}>narratives</a>
          <a href={href("/emerging")} class={active === "emerging" ? "active" : ""}>emerging</a>
          <a href={href("/guide")} class={active === "guide" ? "active" : ""}>guide</a>
          <a href={href("/data")} class={active === "data" ? "active" : ""}>data</a>
          <a href={href("/research")} class={active === "research" ? "active" : ""}>research</a>
        </nav>
      </div>
    </header>
    <main>
      {wide ? <slot /> : <div class="wrap"><slot /></div>}
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <span>ellis garver · macro narrative dynamics</span>
        <span>
          <a href="https://github.com/ellisgarver/macro-narrative-dynamics" target="_blank" rel="noopener">github</a>
          · <a href="mailto:ehgarver@uchicago.edu">ehgarver@uchicago.edu</a>
        </span>
      </div>
    </footer>

    <script>
      // a refresh should always land at the top with the entrance animations
      // replayed, not restore the previous scroll position mid-page.
      if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      window.scrollTo(0, 0);

      // scroll-reveal: fade-and-lift elements tagged .reveal as they enter view
      const els = document.querySelectorAll(".reveal");
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("in"));
      }
    </script>

    <style>
      /* comic virus mascot — a spinning corona with a little face. it is the
         contagion theme made literal: narratives spread like this. lives in the
         shared header so it rides along on every page. */
      .brand { display: inline-flex; align-items: center; gap: 0.5rem; }
      .virus { width: 27px; height: 27px; flex: none; display: block; animation: v-bob 3.6s ease-in-out infinite; }
      .virus .spikes line { stroke: var(--accent); stroke-width: 1.8; stroke-linecap: round; }
      .virus .spikes circle { fill: var(--accent); }
      .virus .spikes { transform-box: fill-box; transform-origin: center; animation: v-spin 14s linear infinite; }
      .virus .body { fill: var(--accent); transform-box: fill-box; transform-origin: center; animation: v-breathe 3s ease-in-out infinite; }
      /* a big-eyed, beaming face: two large forward eyes with sparkle highlights,
         raised brows, and a wide open grin with teeth and a tongue. */
      .virus .eye { fill: var(--paper); }
      .virus .pupil { fill: var(--ink); }
      .virus .mouth { fill: var(--decay); }
      .virus .tongue { fill: color-mix(in srgb, var(--decay) 55%, var(--paper)); }
      .virus .tooth { fill: var(--paper); }
      .virus .face { transform-box: fill-box; transform-origin: center; animation: v-wiggle 5s ease-in-out infinite; }
      .brand:hover .spikes { animation-duration: 3s; }
      .brand:hover .virus { animation-duration: 1.4s; }
      @keyframes v-spin { to { transform: rotate(360deg); } }
      @keyframes v-breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.06); } }
      @keyframes v-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-1.5px); } }
      @keyframes v-wiggle { 0%, 100% { transform: rotate(-3deg); } 50% { transform: rotate(3deg); } }
      @media (prefers-reduced-motion: reduce) {
        .virus, .virus .spikes, .virus .body, .virus .face { animation: none; }
      }
    </style>
  </body>
</html>
