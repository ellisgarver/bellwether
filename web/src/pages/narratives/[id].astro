---
import Base from "../../layouts/Base.astro";
import StageBadge from "@components/StageBadge.astro";
import { loadIndex, loadNarrative, labelMap, displayName, JEL_NAME } from "@lib/data";

export function getStaticPaths() {
  const index = loadIndex();
  return index.narratives.map((e) => ({
    params: { id: String(e.cluster_id) },
    props: { entry: e },
  }));
}

const { entry } = Astro.props;
const n = loadNarrative(entry.cluster_id);
const index = loadIndex();
const labels = labelMap(index);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const fmt = (x: number | null, d = 2) =>
  x === null || x === undefined ? "—" : x.toFixed(d);
const sd = n.stage_detail || {};
// plain-language gloss of the model-free trend test that decides the stage.
const trendWord =
  sd.trend === "increasing"
    ? "rising"
    : sd.trend === "decreasing"
      ? "falling"
      : "no monotonic trend";
const facts = n.shape_facts || {};
// Three representative-article panels (ADR-061): how the narrative entered, its
// core pieces, and where it stands now. Falls back to the single legacy list for
// pre-ADR-061 artifacts, and drops any empty panel.
const repPanels = [
  { label: "core pieces", items: n.card.central_articles ?? n.card.representative_articles ?? [] },
  { label: "earliest", items: n.card.earliest_articles ?? [] },
  { label: "most recent", items: n.card.newest_articles ?? [] },
].filter((p) => p.items.length > 0);
const factOrder: [string, string][] = [
  ["total_volume", "total volume"],
  ["peak_volume", "peak volume"],
  ["time_to_peak_days", "time to peak (days)"],
  ["active_days", "active days"],
  ["wave_count", "peaks (≥ ½ max)"],
];
const linkList = (ids: number[]) =>
  ids.length
    ? ids.map((id) => ({ id, label: labels[id] ?? `#${id}` }))
    : null;

const SERIES_LABEL: Record<string, string> = {
  vix: "VIX",
  "10y_yield": "10-year yield",
  yield_spread: "yield spread (10y–2y)",
};
const fmtSeries = (s: string | null | undefined) =>
  !s ? "market" : SERIES_LABEL[s] ?? s.replace(/_/g, " ");
const mlabel = n.markets ? fmtSeries(n.markets.series_label) : null;
const mkg = n.markets?.granger ?? null;
const mcg = n.mediacloud?.granger ?? null;
// one row of a Granger readout: "<from> → <to>" with significance + (p, lag).
const direction = (d: any) =>
  !d
    ? "—"
    : `${d.significant ? "significant" : "not significant"} (p = ${fmt(d.min_p, 3)}, lag ${d.best_lag})`;
---

<Base title={displayName(n)} active="narratives">
  <p class="back reveal"><a href={`${base}/narratives`}>← all narratives</a></p>
  <h1 class="reveal">{displayName(n)}</h1>
  {n.description && <p class="reveal" style="margin:0.2rem 0 0.4rem;color:var(--muted)">{n.description}</p>}
  <p class="lede reveal" style="margin-bottom:0.4rem">
    {n.card.n_articles} articles
    {n.card.date_range && <> · {n.card.date_range[0]} → {n.card.date_range[1]}</>}
    {n.jel && <> · <abbr title={JEL_NAME[n.jel.code] ?? n.jel.code}>JEL {n.jel.code}</abbr></>}
    <span class="sep">|</span>
    <StageBadge stage={n.stage} emerging={entry.is_emerging} inScope={n.jel?.in_scope ?? true} />
  </p>

  <!-- life-cycle chart -->
  <section class="section reveal">
    <p class="eyebrow">life-cycle</p>
    <h2>how the volume rose and fell</h2>
    <div class="lens-bar">
      <div class="tabs" id="lens-tabs"></div>
      {(n.mediacloud || n.markets) && (
        <div class="toggle-row" id="overlay-toggles">
          {n.mediacloud && (
            <label class="toggle"><input type="checkbox" id="t-press" /> broad-press volume (Media Cloud)</label>
          )}
          {n.markets && (
            <label class="toggle"><input type="checkbox" id="t-market" /> {mlabel} (markets)</label>
          )}
        </div>
      )}
    </div>
    <div id="vol-legend" class="vol-legend"></div>
    <div id="vol-chart" class="chart"></div>
    <div class="zoom-controls">
      <label class="zoom">
        <span>time zoom</span>
        <input type="range" id="zoom-x" min="0" max="1" step="0.01" value="0" aria-label="time (horizontal) zoom" />
      </label>
      <label class="zoom">
        <span>volume zoom</span>
        <input type="range" id="zoom-y" min="0" max="1" step="0.01" value="0" aria-label="volume (vertical) zoom" />
      </label>
    </div>
  </section>

  <!-- stage + shape facts -->
  <section class="section reveal">
    <div class="cols-2">
      <div>
        <p class="eyebrow">where it sits now</p>
        <h2>{n.stage} characterization</h2>
        <table class="facts">
          <tr><td>trajectory test</td><td>modified Mann–Kendall</td></tr>
          <tr><td>recent trend</td><td>{trendWord}</td></tr>
          <tr><td>significance</td><td>{sd.trend_p != null ? `p = ${fmt(sd.trend_p, 3)} (α = ${fmt(sd.alpha, 2)})` : "—"}</td></tr>
          <tr><td>recent log-slope</td><td>{sd.trend_slope != null ? `${fmt(sd.trend_slope, 3)} / day` : "—"}</td></tr>
          <tr><td>vs own peak</td><td>{sd.recent_peak_ratio == null ? "—" : `${Math.round(sd.recent_peak_ratio * 100)}% of peak level${sd.recent_near_peak ? "" : " — faded"}`}</td></tr>
        </table>
        <p class="caption">
          {sd.r0_mean != null ? (
            <>SIR lens (display only): R₀ {fmt(sd.r0_mean)}{sd.r0_ci_low != null && <> [{fmt(sd.r0_ci_low)}–{fmt(sd.r0_ci_high)}]</>}. R₀ gauges how contagious the wave was, not where it sits now.</>
          ) : (
            <>SIR lens did not converge here; the stage is read from the trend test above.</>
          )}
        </p>
      </div>
      <div>
        <p class="eyebrow">shape facts</p>
        <h2>measured directly from the curve</h2>
        <table class="facts">
          {factOrder.filter(([k]) => k in facts).map(([k, lbl]) => (
            <tr><td>{lbl}</td><td>{facts[k].toLocaleString(undefined, { maximumFractionDigits: 1 })}</td></tr>
          ))}
        </table>
      </div>
    </div>
  </section>

  {(n.markets || n.mediacloud) && (
    <section class="section reveal">
      <div class="cols-2">
        {n.markets && mkg && (
          <div>
            <p class="eyebrow">markets</p>
            <h2>did discourse lead or lag {mlabel}?</h2>
            <p class="note">{mkg.verdict}</p>
            <dl class="kv" style="margin-top:0.8rem">
              <dt>discourse → {mlabel}</dt>
              <dd>{direction(mkg.volume_leads_market)}</dd>
              <dt>{mlabel} → discourse</dt>
              <dd>{direction(mkg.market_leads_volume)}</dd>
            </dl>
          </div>
        )}
        {n.mediacloud && (
          <div>
            <p class="eyebrow">broad-press</p>
            <h2>did discourse lead or lag press?</h2>
            {mcg ? (
              <>
                <p class="note">{mcg.verdict}</p>
                <dl class="kv" style="margin-top:0.8rem">
                  <dt>discourse → press</dt>
                  <dd>{direction(mcg.volume_leads_market)}</dd>
                  <dt>press → discourse</dt>
                  <dd>{direction(mcg.market_leads_volume)}</dd>
                </dl>
              </>
            ) : (
              <p class="note">press lead-lag unavailable for this window.</p>
            )}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- representative articles -->
  <section class="section reveal">
    <p class="eyebrow">in the corpus</p>
    <h2>representative writing</h2>
    <div class="rep-panels">
      {repPanels.map((p) => (
        <div class="rep-panel">
          <h3 class="rep-panel-title">{p.label}</h3>
          <ul class="reps">
            {p.items.map((a) => (
              <li>
                <a href={a.url} target="_blank" rel="noopener">{a.title}</a>
                <div class="meta">{a.source_id} · {a.published_at}</div>
                {a.excerpt && <p class="excerpt">{a.excerpt}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    {n.card.source_mix?.length > 0 && (
      <p class="caption">sources: {n.card.source_mix.slice(0, 6).map(([s, c]) => `${s} (${c})`).join(", ")}</p>
    )}
  </section>

  {n.similar && (n.similar.semantic.length + n.similar.lexical.length + n.similar.morphological.length > 0) && (
    <section class="section reveal">
      <p class="eyebrow">nearby</p>
      <h2>related narratives</h2>
      <dl class="kv related">
        <dt>by meaning</dt>
        <dd>{linkList(n.similar.semantic)
          ? linkList(n.similar.semantic).map((x, i) => <>{i ? ", " : ""}<a href={`${base}/narratives/${x.id}`}>{x.label}</a></>)
          : "—"}</dd>
        <dt>by terms</dt>
        <dd>{linkList(n.similar.lexical)
          ? linkList(n.similar.lexical).map((x, i) => <>{i ? ", " : ""}<a href={`${base}/narratives/${x.id}`}>{x.label}</a></>)
          : "—"}</dd>
        <dt>by curve shape</dt>
        <dd>{linkList(n.similar.morphological)
          ? linkList(n.similar.morphological).map((x, i) => <>{i ? ", " : ""}<a href={`${base}/narratives/${x.id}`}>{x.label}</a></>)
          : "—"}</dd>
      </dl>
    </section>
  )}

  <script id="narr-data" type="application/json" set:html={JSON.stringify(n)}></script>
  <script>
    import { Plotly, baseLayout, COL, HOVER_LABEL, seriesLabel } from "@lib/chart";
    const n = JSON.parse(document.getElementById("narr-data").textContent);
    const chartEl = document.getElementById("vol-chart");
    const legendEl = document.getElementById("vol-legend");
    const tabsEl = document.getElementById("lens-tabs");
    const dates = n.volume.dates;
    const vol = n.volume.values;
    const maxVol = Math.max(1, ...vol);

    // x bounds in epoch-ms: the full timeline, edge to edge, no margin. this is
    // the default ("most zoomed out") view; the time slider only zooms in.
    const xLoMs = Date.parse(dates[0]);
    const xHiMs = Date.parse(dates[dates.length - 1]);
    const xFull = xHiMs - xLoMs || 864e5;

    function normalise(arr) {
      const xs = arr.filter((v) => v != null && isFinite(v));
      if (!xs.length) return arr.map(() => null);
      const lo = Math.min(...xs), hi = Math.max(...xs);
      const span = hi - lo || 1;
      return arr.map((v) => (v == null || !isFinite(v) ? null : ((v - lo) / span) * maxVol));
    }
    function alignTo(grid, oDates, oVals) {
      const m = new Map(oDates.map((d, i) => [d, oVals[i]]));
      return grid.map((d) => (m.has(d) ? m.get(d) : null));
    }

    const fits = n.fits;
    let activeFit = fits.findIndex((f) => f.model === n.staging_model);
    if (activeFit < 0) activeFit = 0;

    fits.forEach((f, i) => {
      const b = document.createElement("button");
      b.className = "tab" + (i === activeFit ? " active" : "");
      b.textContent = f.model + (f.converged ? "" : " (no fit)");
      b.disabled = !f.converged || !f.curve;
      if (b.disabled) b.title = f.failure_reason || "fit did not converge";
      b.addEventListener("click", () => {
        activeFit = i; resetView(); render();
        [...tabsEl.children].forEach((c, j) => c.classList.toggle("active", j === i));
      });
      tabsEl.appendChild(b);
    });

    const pressEl = document.getElementById("t-press");
    const marketEl = document.getElementById("t-market");
    pressEl && pressEl.addEventListener("change", render);
    marketEl && marketEl.addEventListener("change", render);

    // one-line hover: trace name, date, value — all in a single chip so the
    // name never spills into Plotly's separate (white, trace-colored) box.
    const hov = (label) =>
      `${label} · %{x|%b %-d, %Y} · %{y:.2f}<extra></extra>`;

    // ---- view state: drag pans the center, the sliders zoom in ----
    // y top spans every lens (not just the active one) so the scale stays put
    // when switching lenses. it is fixed — zooming never changes the max, only
    // how much of [0, yTop] is shown ("y max stays regardless of zoom").
    const yTop = Math.max(
      maxVol,
      ...fits.flatMap((f) => (f.curve || []).filter((v) => v != null && isFinite(v))),
    ) * 1.08;
    // sliders run 0 (full view, "most zoomed out") to 1 (deepest zoom); 10^value
    // gives smooth log steps. there is no zoom-out past the full timeline.
    const ZOOM_BASE = 10;
    let zx = 1, zy = 1;
    let cx = (xLoMs + xHiMs) / 2;   // x center (epoch-ms)
    let cy = yTop / 2;              // y center
    function viewRange() {
      const xs = xFull / zx, ys = yTop / zy;
      // pan within the data extent; at zoom 1 these clamps pin the view to the
      // full timeline and the full [0, yTop] height. the floor and ceiling are
      // both strict, so the view never shows below 0 or above the data max.
      cx = Math.min(xHiMs - xs / 2, Math.max(xLoMs + xs / 2, cx));
      cy = Math.min(yTop - ys / 2, Math.max(ys / 2, cy));
      return { x: [cx - xs / 2, cx + xs / 2], y: [cy - ys / 2, cy + ys / 2] };
    }

    const zxEl = document.getElementById("zoom-x");
    const zyEl = document.getElementById("zoom-y");
    const applyZoom = () => {
      const vr = viewRange();
      Plotly.relayout(chartEl, { "xaxis.range": vr.x, "yaxis.range": vr.y });
    };
    // reset pan + zoom to the full view (used when switching fit lens).
    function resetView() {
      zx = 1; zy = 1;
      cx = (xLoMs + xHiMs) / 2; cy = yTop / 2;
      zxEl.value = "0"; zyEl.value = "0";
    }
    zxEl.addEventListener("input", () => { zx = ZOOM_BASE ** parseFloat(zxEl.value); applyZoom(); });
    // volume zoom keeps the data max pinned at the top: anchor the window's top
    // at yTop so zooming reveals the peak in finer detail without moving the max.
    zyEl.addEventListener("input", () => {
      zy = ZOOM_BASE ** parseFloat(zyEl.value);
      cy = yTop - (yTop / zy) / 2;
      applyZoom();
    });

    render();

    // drag is a pure pan: we own it so a drag can only translate the view, never
    // rescale it (Plotly's native pan squishes the range at a bound, which read
    // back as an unwanted zoom). pixel deltas convert to data via the plot-area
    // length; viewRange() then clamps to the strict bounds. move/up live on the
    // window so a drag keeps going off the chart and — critically — the release
    // is always caught, even outside the plot, so it can't get stuck "dragging".
    let dragging = false, lastX = 0, lastY = 0;
    chartEl.addEventListener("pointerdown", (ev) => {
      dragging = true; lastX = ev.clientX; lastY = ev.clientY;
      chartEl.classList.add("dragging");
    });
    window.addEventListener("pointermove", (ev) => {
      if (!dragging) return;
      const fl = chartEl._fullLayout;
      if (!fl) return;
      const xLen = fl.xaxis._length, yLen = fl.yaxis._length;
      cx -= (ev.clientX - lastX) * (xFull / zx) / xLen;
      cy += (ev.clientY - lastY) * (yTop / zy) / yLen;
      lastX = ev.clientX; lastY = ev.clientY;
      const vr = viewRange();
      Plotly.relayout(chartEl, { "xaxis.range": vr.x, "yaxis.range": vr.y });
    });
    const endDrag = () => {
      if (!dragging) return;
      dragging = false; chartEl.classList.remove("dragging");
    };
    window.addEventListener("pointerup", endDrag);
    window.addEventListener("pointercancel", endDrag);

    function render() {
      const traces = [
        { x: dates, y: vol, type: "bar", name: "adjusted volume",
          marker: { color: "rgba(47,75,124,0.22)" },
          hovertemplate: hov("adjusted volume") },
      ];
      const f = fits[activeFit];
      if (f && f.curve) {
        traces.push({ x: dates, y: f.curve, type: "scatter", mode: "lines",
          name: `${f.model} fit`, line: { color: COL.accent, width: 2.6 },
          hovertemplate: hov(`${f.model} fit`) });
      }
      if (pressEl && pressEl.checked && n.mediacloud) {
        const aligned = alignTo(dates, n.mediacloud.dates, n.mediacloud.story_count);
        traces.push({ x: dates, y: normalise(aligned), type: "scatter", mode: "lines",
          name: "press (scaled)", connectgaps: true,
          line: { color: COL.ember, width: 2, dash: "dot" },
          hovertemplate: hov("press (scaled)") });
      }
      if (marketEl && marketEl.checked && n.markets) {
        const aligned = alignTo(dates, n.markets.dates, n.markets.market);
        traces.push({ x: dates, y: normalise(aligned), type: "scatter", mode: "lines",
          name: `${seriesLabel(n.markets.series_label)} (scaled)`, connectgaps: true,
          line: { color: COL.decay, width: 2, dash: "dash" },
          hovertemplate: hov(`${seriesLabel(n.markets.series_label)} (scaled)`) });
      }
      // custom HTML legend instead of Plotly's. Plotly's built-in legend can
      // only anchor to the plot area (indented by the y-axis margin) or to the
      // container — and the container anchor makes autoexpand inflate the left
      // margin in proportion to viewport width, shoving the plot right with a
      // big empty gutter at wide windows. an HTML row at the page-content left
      // edge sits flush under the tabs and never touches Plotly's margins.
      // styling is fully inline: these chips are injected via innerHTML, so
      // Astro's scoped CSS (which tags template elements with a data-astro-cid
      // attribute) never reaches them and a class-based display/size rule would
      // silently not apply — collapsing the swatch box to a sliver.
      const swBase = "display:inline-block;vertical-align:middle;margin-right:0.4rem;";
      legendEl.innerHTML = traces
        .map((t) => {
          let sw;
          if (t.type === "bar") {
            sw = `<span style="${swBase}width:0.8rem;height:0.8rem;border-radius:2px;background:${t.marker.color}"></span>`;
          } else if (t.line.dash) {
            const c = t.line.color;
            // mirror the line's dash style so the legend distinguishes the
            // overlays: "dot" → tight round-ish dots, "dash" → longer dashes.
            const stripe =
              t.line.dash === "dot"
                ? `repeating-linear-gradient(90deg,${c} 0 2px,transparent 2px 5px)`
                : `repeating-linear-gradient(90deg,${c} 0 6px,transparent 6px 10px)`;
            sw = `<span style="${swBase}width:1.5rem;height:3px;border-radius:1px;background:${stripe}"></span>`;
          } else {
            sw = `<span style="${swBase}width:1.5rem;height:3px;border-radius:1px;background:${t.line.color}"></span>`;
          }
          return `<span class="leg-item">${sw}${t.name}</span>`;
        })
        .join("");
      // fixed margins (no automargin): automargin recomputes the plot area
      // whenever the visible tick labels change width, which on a date axis
      // happens every pan frame — that reflow was the jitter. the range comes
      // from the shared view state so a lens switch keeps the current pan/zoom.
      const vr = viewRange();
      const layout = baseLayout({
        bargap: 0.06,
        dragmode: false,
        showlegend: false,
        margin: { l: 64, r: 18, t: 8, b: 46 },
        xaxis: { type: "date", gridcolor: "rgba(226,220,207,0.6)", range: vr.x },
        yaxis: {
          title: { text: "corpus-size-adjusted volume", standoff: 14 },
          gridcolor: "rgba(226,220,207,0.6)", range: vr.y,
        },
      });
      // pin the hover chip per-trace: otherwise a translucent marker/line color
      // (e.g. the faint blue volume bars) bleeds into the chip background.
      traces.forEach((t) => (t.hoverlabel = HOVER_LABEL));
      // we own drag (custom pan) and zoom (the sliders), so every native range
      // interaction is off; relayout calls drive the view instead.
      Plotly.react(chartEl, traces, layout, {
        displayModeBar: false, responsive: true, scrollZoom: false, doubleClick: false,
      });
    }
  </script>
</Base>

<style>
  /* the index/emerging/guide page titles use the larger homepage --fs-title,
     but a single narrative's name is a label, not a page banner — keep it at
     the pre-change h1 size so it doesn't dwarf the meta line beneath it. */
  h1 { font-size: clamp(2rem, 4vw, 3.1rem); }
  .back { margin: 0 0 0.6rem; }
  /* a single divider between the JEL code and the color-bubble tags, replacing
     the gray dot separators around them. */
  .sep { color: var(--line); margin: 0 0.5rem; }
  .lede :global(.badge) { vertical-align: middle; margin-right: 0.3rem; }
  .section:first-of-type { padding-top: 1rem; }
  /* lens tabs on the left, overlay checkboxes pinned to the right, one line */
  .lens-bar {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem 2rem; flex-wrap: wrap;
    border-bottom: 1px solid var(--line); margin: 1.2rem 0 0.4rem;
  }
  .lens-bar :global(.tabs) { border-bottom: none; margin: 0; }
  .lens-bar :global(.toggle-row) { margin: 0; }
  /* custom chart legend: a flat row of swatch+label chips. left padding matches
     the tab text inset (.tab padding-left is 0.95rem) so the first swatch sits
     flush under the "logistic" tab rather than indented by the y-axis margin. */
  .vol-legend {
    display: flex; flex-wrap: wrap; gap: 0.3rem 1.4rem; align-items: center;
    padding-left: 0.95rem; margin: 1.5rem 0;
    font-size: var(--fs-meta); color: var(--muted);
  }
  /* the volume chart owns horizontal drag-to-pan; let the browser keep vertical
     touch-scroll so a finger-drag over the chart never traps the page scroll. */
  #vol-chart { touch-action: pan-y; }
  /* two zoom sliders sitting side by side under the chart — drag pans, these
     scale time and volume independently. accent-color matches the page toggles. */
  .zoom-controls { display: flex; gap: 2rem; align-items: center; margin: 0.6rem 0 0; }
  .zoom {
    flex: 1; display: flex; align-items: center; gap: 0.6rem;
    font-size: var(--fs-meta); color: var(--faint); letter-spacing: 0.03em;
  }
  .zoom span { white-space: nowrap; }
  .zoom input[type="range"] { flex: 1; accent-color: var(--accent); cursor: pointer; }
  /* the two sliders crush together below ~420px; stack them instead. */
  @media (max-width: 420px) {
    .zoom-controls { flex-direction: column; gap: 0.6rem; align-items: stretch; }
  }
  /* only two cursors over the chart: the default arrow (Plotly's crosshair is
     suppressed) and a closed grabbing hand while a drag is in progress. */
  .chart :global(.nsewdrag),
  .chart :global(.drag) { cursor: default !important; }
  .chart.dragging :global(.nsewdrag),
  .chart.dragging :global(.drag) { cursor: grabbing !important; }
  .rep-panels {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem 2.5rem;
  }
  .rep-panel-title {
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 0.35rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--line-soft);
  }
  .reps { list-style: none; margin: 0; padding: 0; }
  .reps li { padding: 0.9rem 0; border-bottom: 1px solid var(--line-soft); }
  .reps a { font-weight: 600; }
  .reps .meta { color: var(--muted); font-size: var(--fs-meta); margin-top: 0.15rem; }
