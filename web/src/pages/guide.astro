---
import Base from "../layouts/Base.astro";
import { loadIndex, loadNarrative, displayName } from "@lib/data";
const index = loadIndex();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Walkthrough example: a recognizable macro story whose best converged lens
// also fits well, so the reader's first chart is both familiar and clearly
// curve-tracked. We bias toward a shortlist of well-known narratives, then pick
// the highest-R² match; if none are present we fall back to the best-fitting
// in-scope narrative so the page always has a good example.
const bestR2 = (cid: number): number => {
  const fits = loadNarrative(cid).fits ?? [];
  return Math.max(
    0,
    ...fits
      .filter((f) => f.converged && f.curve)
      .map((f) => (typeof f.params?.r2 === "number" ? (f.params.r2 as number) : 0)),
  );
};
const FAMILIAR = [
  "china", "trade war", "tariff", "inflation", "eurozone", "sovereign debt",
  "brexit", "debt ceiling", "quantitative easing", "oil", "infrastructure",
  "soft landing", "yield curve", "housing",
];
const isFamiliar = (e: (typeof index.narratives)[number]): boolean => {
  const hay = (displayName(e) + " " + e.label + " " + (e.top_terms ?? []).join(" ")).toLowerCase();
  return FAMILIAR.some((k) => hay.includes(k));
};
const inScope = index.narratives.filter((e) => e.in_scope);
const pool = inScope.length ? inScope : index.narratives;
const familiar = pool.filter(isFamiliar);
let example = pool[0] ?? index.narratives[0];
let exampleScore = -1;
for (const e of (familiar.length ? familiar : pool)) {
  const s = bestR2(e.cluster_id);
  if (s > exampleScore) {
    exampleScore = s;
    example = e;
  }
}

// the walkthrough inventory: everything a narrative page holds, top to bottom.
// one-line rows that disclose their reading on click, like the data-page feeds.
const walkthrough: [string, string][] = [
  ["the bars", "weekly volume, adjusted for how much the whole corpus published that week — the measured story itself."],
  ["the lens tabs", "one per lens, each carrying its R². the chart opens on the best-fitting lens; grayed tabs are weak fits that stay clickable for comparison, and clicking the active tab clears the curve back to the bars alone."],
  ["pan & zoom", "drag pans the view; the two sliders zoom time and volume independently."],
  ["the stage readout", "the numbers behind the stage call: the trend direction, its p-value against α = 0.05, the recent log-slope, and recent volume as a share of the narrative's own peak."],
  ["the shape facts", "total and peak volume, time to peak, active days, and wave count, read straight off the curve."],
  ["the overlay checkboxes", "broad-press story counts (Media Cloud, thin before ~2017) and a market series (VIX), each min-max rescaled onto the volume axis — its own low at the floor, its own high at the tallest bar — so an overlay carries timing and shape, never height."],
  ["the lead-lag readout", "the two Granger verdicts, each direction reported with its significance, p-value, and best lag."],
];
---

<Base title="guide" active="guide">
  <h1 class="reveal">how bellwether works</h1>
  <p class="lede reveal">
    the pipeline that turns institutional writing into clustered narratives and
    lifecycle analysis.
  </p>

  <section class="section reveal">
    <h2>from articles to narratives</h2>

    <figure class="pipeline reveal">
      <div class="pipe">
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <rect x="6" y="3" width="16" height="22" rx="1.5" />
              <line x1="9" y1="9" x2="19" y2="9" /><line x1="9" y1="13" x2="19" y2="13" />
              <line x1="9" y1="17" x2="16" y2="17" />
            </svg>
          </span>
          <span class="ptext"><strong>articles</strong>whole context</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <rect x="6" y="3" width="16" height="22" rx="1.5" />
              <line class="cut" x1="6" y1="11" x2="22" y2="11" />
              <line class="cut" x1="6" y1="18" x2="22" y2="18" />
            </svg>
          </span>
          <span class="ptext"><strong>passages</strong>≈512-token chunks</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <circle cx="8" cy="9" r="1.6" /><circle cx="15" cy="6" r="1.6" />
              <circle cx="21" cy="11" r="1.6" /><circle cx="11" cy="16" r="1.6" />
              <circle cx="19" cy="19" r="1.6" /><circle cx="7" cy="22" r="1.6" />
            </svg>
          </span>
          <span class="ptext"><strong>embeddings</strong>Qwen3 vectors</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <circle class="hull" cx="7" cy="7" r="6" />
              <circle class="hull" cx="21" cy="21" r="6" />
              <circle cx="7" cy="5.5" r="1.4" /><circle cx="5.5" cy="8.5" r="1.4" /><circle cx="8.5" cy="8.5" r="1.4" />
              <circle cx="21" cy="19.5" r="1.4" /><circle cx="19.5" cy="22.5" r="1.4" /><circle cx="22.5" cy="22.5" r="1.4" />
            </svg>
          </span>
          <span class="ptext"><strong>clusters</strong>UMAP + HDBSCAN</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <path d="M5 9 h11 l6 5 -6 5 H5 z" />
              <circle class="tag-eye" cx="9" cy="14" r="1.4" />
            </svg>
          </span>
          <span class="ptext"><strong>label + scope</strong>c-TF-IDF, JEL</span>
        </div>
      </div>
    </figure>

    <p>
      each article is split into passages of roughly 512 tokens, the retrieval
      unit from the BEIR benchmark, so long reports are read in coherent pieces.
      each passage becomes a vector from a sentence-embedding model
      (Qwen3-Embedding-8B, 4,096 numbers per passage) in a space where closeness
      tracks meaning: two passages making similar arguments land near each other numerically.
    </p>
    <p>
      those vectors are clustered with BERTopic, which reduces them to a lower
      dimension (UMAP), finds dense regions of related passages (HDBSCAN), and then
      names each region by the terms that are frequent within but rare elsewhere
      (a class-based TF-IDF). density-based clustering leaves passages belonging to no clear group as outliers, and each
      surviving group is a narrative candidate.
    </p>
    <p>
      scope is decided after clustering with each cluster matched to the
      standard JEL economics
      taxonomy published by the American Economic Association. this is done by comparing the
      cluster's center to a prototype vector for each JEL field and taking the
      nearest one. clusters in the macro-finance fields, JEL E (macroeconomics and
      monetary), F (international), G (financial), and H (public and fiscal), are
      the core scope; clusters that fall outside those fields are still fit and
      shown, just flagged with the external JEL field they landed in.
    </p>
    <p>
      the display names come from a small language model (llama 3.1-8B)
      . it reads each cluster's terms, excerpts from
      its most central articles, its date span, and its source mix, then writes
      a short title and description. a defined cluster here is a
      long-lived family of related writing rather than a single news story. new
      events usually land inside an old family (ex. the
      2026 Iran war joins sanctions clusters from 2010).
    </p>
  </section>

  <section class="section reveal">
    <h2>four lenses, a stage, and statistical analysis</h2>
    <p>
      counting a narrative's articles per week gives a volume curve: a time series
      of how loud the story is. that count is then normalized for how much the whole
      corpus published that day, so a story doesn't look like it's growing just because
      coverage overall grew. four lenses are applied to the adjusted curve and shown
      side by side. each lens encodes a different assumption about how a story spreads:
    </p>
    <div class="lenses">
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,42 C40,42 44,30 60,24 C76,18 80,6 114,6" />
        </svg>
        <div>
          <strong>logistic growth</strong> <span class="cite">(Verhulst, 1838)</span>
          <p>a characteristic S-shaped rise to a saturation ceiling, governed by a growth rate and a carrying capacity.</p>
        </div>
      </div>
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,44 C36,44 46,6 60,6 C74,6 84,44 114,44" />
        </svg>
        <div>
          <strong>SIR epidemic</strong> <span class="cite">(Kermack &amp; McKendrick, 1927)</span>
          <p>treats attention as an outbreak that spreads, peaks, and burns out, measured by doubling and halving speed.</p>
        </div>
      </div>
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,44 C16,44 20,30 28,30 C36,30 38,40 48,40 C64,40 74,8 92,8 C104,8 110,38 114,42" />
        </svg>
        <div>
          <strong>Bass diffusion</strong> <span class="cite">(Bass, 1969)</span>
          <p>shows adoption via innovators (who initiate the story) and imitators (who pick it up from others), with a coefficient for each.</p>
        </div>
      </div>
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,44 C36,44 46,8 60,8 C74,8 84,44 114,44" />
          <line class="gd" x1="60" y1="8" x2="60" y2="44" />
          <circle class="pk" cx="60" cy="8" r="3" />
        </svg>
        <div>
          <strong>shape facts</strong>
          <p>model-free readings taken straight from a view of the true curve: time to peak, total volume, number of distinct waves.</p>
        </div>
      </div>
    </div>
    <p>
      each curve is fit by bounded least squares and scored with R², the share of
      the volume's variation the curve explains. every lens stays available on
      every narrative, opening on the best-scoring one. weaker lenses are
      grayed not hidden, and the score sits on the tab. when no lens
      describes the narrative well it opens on the volume alone, and the grayed
      tabs still pull any lens up for comparison.
    </p>
    <p>
      the lenses describe shape but don't assign stage. instead, the stage is read
      directly from the recent curve with a known model-free trend test: a modified
      Mann–Kendall test <span class="cite">(Mann, 1945; Kendall, 1948)</span> over
      the most recent four weeks, its variance corrected for the autocorrelation
      that smoothing introduces <span class="cite">(Hamed &amp; Rao, 1998)</span>.
      see more on the four narrative stages below:
    </p>
    <ul class="r0">
      <li class="g"><span class="k">growth</span><span>a significant upward trend over the trailing four weeks (Mann–Kendall p &lt; 0.05): attention is rising</span></li>
      <li class="s"><span class="k">stable</span><span>no significant trend, and recent volume holds at 25% or more of the narrative's own peak level: a high plateau</span></li>
      <li class="d"><span class="k">decay</span><span>a significant downward trend over the trailing four weeks (p &lt; 0.05): attention is falling</span></li>
      <li class="z"><span class="k">dormant</span><span>no significant trend, and recent volume has fallen below 25% of the narrative's own peak level: faded out</span></li>
    </ul>
    <p>
      the last piece of analysis connects each narrative to the world outside the
      corpus: two bidirectional Granger tests <span class="cite">(Granger, 1969)</span>,
      one against broad-press story counts (Media Cloud) and one against a market
      series (VIX), both computed on the unscaled weekly series. sweeping by
      lags of one to four weeks in both directions, the tests determine whether past values of one
      series help predict the other, and reports the strongest lag: whether the
      discourse moved before or after the press, and before or after the market, and by how much.
      note that Granger precedence measures timing and not cause. discourse can move first yet not impact press or markets.
    </p>
  </section>

  <section class="section reveal">
    <h2>reading a narrative</h2>
    <p>
      take <a href={`${base}/narratives/${example.cluster_id}`}>{displayName(example)}</a> for
      example. top to bottom, its page holds:
    </p>
    <div class="read-list">
      {walkthrough.map(([k, d], i) => (
        <details class="read-row">
          <summary class="read-head">
            <span class="read-n">{String(i + 1).padStart(2, "0")}</span>
            <span class="read-k">{k}</span>
            <span class="read-cue">+</span>
          </summary>
          <div class="read-detail"><p>{d}</p></div>
        </details>
      ))}
    </div>
    <p>
      further down sits a reading list, three stacked lists linking to
      the source documents: the narrative's core pieces, its earliest writing,
      and its most recent. related narratives close the page, ranked three ways:
      by meaning (closeness of cluster centers in embedding space), by terms
      (shared distinctive vocabulary), and by curve shape (correlation of the
      two volume curves). close neighbors score high on all three.
    </p>
  </section>
</Base>

<style>
  @keyframes draw { from { stroke-dashoffset: 1; } to { stroke-dashoffset: 0; } }

  /* clustering pipeline: a left-to-right flow of glyph steps. each glyph lights up
     in sequence so the eye reads the data moving through the stages. */
  .pipeline { margin: 2.6rem 0; padding: 0.4rem 0; }
  .pipe { display: flex; align-items: stretch; gap: 0.4rem; flex-wrap: wrap; }
  .pstep {
    flex: 1 1 0; min-width: 92px;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 0.5rem; position: relative;
  }
  /* connector arrow between steps */
  .pstep:not(:last-child)::after {
    content: "→"; position: absolute; top: 22px; right: -0.55rem;
    color: var(--faint); font-size: var(--fs-ui); line-height: 1;
  }
  .pglyph {
    display: grid; place-items: center; width: 48px; height: 48px; border-radius: 10px;
    background: var(--paper-2); border: 1px solid var(--line);
    animation: flowpulse 5s ease-in-out infinite;
  }
  .pglyph svg { width: 28px; height: 28px; }
  .pglyph svg :is(rect, line, circle, path) {
    fill: none; stroke: var(--accent); stroke-width: 1.6;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .pglyph svg circle:not(.hull):not(.tag-eye) { fill: var(--accent); stroke: none; }
  .pglyph svg .hull { stroke: var(--ember); stroke-dasharray: 2 2.5; }
  .pglyph svg .cut { stroke: var(--ember); stroke-dasharray: 2 2; }
  .pglyph svg .tag-eye { fill: var(--paper-2); stroke: var(--accent); stroke-width: 1.4; }
  .pstep:nth-child(1) .pglyph { animation-delay: 0s; }
  .pstep:nth-child(2) .pglyph { animation-delay: 0.5s; }
  .pstep:nth-child(3) .pglyph { animation-delay: 1s; }
  .pstep:nth-child(4) .pglyph { animation-delay: 1.5s; }
  .pstep:nth-child(5) .pglyph { animation-delay: 2s; }
  @keyframes flowpulse {
    0%, 100% { background: var(--paper-2); border-color: var(--line); }
    50% { background: color-mix(in srgb, var(--accent) 13%, var(--paper)); border-color: var(--accent); }
  }
  .ptext { display: flex; flex-direction: column; font-size: var(--fs-meta); color: var(--faint); line-height: 1.3; }
  .ptext strong { color: var(--ink); font-size: var(--fs-ui); font-weight: 600; }
  .pipeline figcaption { color: var(--faint); font-size: var(--fs-meta); margin-top: 0.9rem; }
  @media (max-width: 560px) {
    .pipe { flex-direction: column; align-items: stretch; gap: 0.7rem; }
    .pstep { flex-direction: row; gap: 0.8rem; text-align: left; }
    .pstep:not(:last-child)::after { content: "↓"; top: auto; right: auto; left: 23px; bottom: -0.65rem; }
    .ptext { align-items: flex-start; }
  }

  /* lenses: a 2×2 grid of cards, each with a mini sketch of its curve shape that
     redraws on hover. */
  .lenses {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem 2.2rem;
    margin: 1.6rem auto; max-width: 54rem;
  }
  .lens-card {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 0.45rem; padding: 1.3rem 0.6rem; border-top: 1px solid var(--line-soft);
  }
  .mini { width: 168px; height: 56px; display: block; }
  .mini path { fill: none; stroke: var(--accent); stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; }
  .mini .pk { fill: var(--ember); stroke: none; }
  .mini .gd { stroke: var(--line); stroke-width: 1; stroke-dasharray: 2 3; }
  .lens-card:hover .mini path { stroke-dasharray: 1; animation: draw 0.9s var(--ease) forwards; }
  .lens-card > div { max-width: 32ch; }
  .lens-card .cite { color: var(--faint); font-size: var(--fs-meta); font-weight: 400; }
  .lens-card p { margin: 0.3rem 0 0; color: var(--muted); font-size: var(--fs-ui); }

  /* stage states as stage-colored rows: a fixed key column + description, uniform
     rounded full-width bars so the block reads as a finished table. */
  .r0 { list-style: none; padding: 0; margin: 1.2rem 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .r0 li {
    display: grid; grid-template-columns: 6rem 1fr; align-items: center; gap: 1rem;
    padding: 0.7rem 3.5rem 0.7rem 1rem; border-radius: 8px;
    background: var(--paper-2); border-left: 3px solid var(--line); color: var(--muted);
  }
  .r0 .k {
    justify-self: start; font-weight: 700; font-variant-numeric: tabular-nums;
    white-space: nowrap; padding: 0.1rem 0.55rem; border-radius: 999px; font-size: var(--fs-ui);
  }
  .r0 .g { border-left-color: var(--growth); }
  .r0 .g .k { color: var(--growth); background: color-mix(in srgb, var(--growth) 14%, var(--paper)); }
  .r0 .s { border-left-color: var(--stable); }
  .r0 .s .k { color: var(--stable); background: color-mix(in srgb, var(--stable) 14%, var(--paper)); }
  .r0 .d { border-left-color: var(--decay); }
  .r0 .d .k { color: var(--decay); background: color-mix(in srgb, var(--decay) 14%, var(--paper)); }
  .r0 .z { border-left-color: var(--dormant); }
  .r0 .z .k { color: #57534a; background: color-mix(in srgb, var(--dormant) 20%, var(--paper)); }
  @media (max-width: 480px) {
    .r0 li { grid-template-columns: 1fr; gap: 0.35rem; }
  }

  /* the walkthrough inventory: one-line rows that disclose their reading on
     click — the same numbered-row disclosure pattern as the data-page feeds. */
  .read-list { margin: 1.2rem 0; }
  .read-row { border-bottom: 1px solid var(--line-soft); transition: background 0.2s var(--ease); }
  .read-row:hover { background: var(--paper-2); }
  .read-head {
    display: grid; grid-template-columns: 2.4rem 1fr auto; align-items: center;
    gap: 0.9rem; padding: 0.8rem 0.5rem; cursor: pointer; list-style: none;
  }
  .read-head::-webkit-details-marker { display: none; }
  .read-n { color: var(--faint); font-variant-numeric: tabular-nums; font-size: var(--fs-meta); }
  .read-k { font-weight: 600; color: var(--ink); }
  .read-cue {
    color: var(--accent); font-weight: 600; font-size: var(--fs-lede); line-height: 1;
    transition: transform 0.3s var(--ease), color 0.2s var(--ease);
  }
  .read-row[open] .read-cue { transform: rotate(45deg); color: var(--accent-bright); }
  .read-detail p {
    margin: 0; padding: 0.1rem 0.5rem 0.9rem 3.8rem;
    color: var(--muted); font-size: var(--fs-ui);
  }

  @media (max-width: 640px) {
    .lenses { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pglyph { animation: none; }
    .lens-card:hover .mini path { animation: none; }
    .read-cue { transition: none; }
  }
</style>
