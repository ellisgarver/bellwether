---
import Base from "../layouts/Base.astro";
import { loadIndex } from "@lib/data";

const index = loadIndex();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const entries = index.narratives;
const hasMap = entries.some((e) => e.umap_xyz || e.umap_xy);
const totalArticles = entries.reduce((s, e) => s + e.n_articles, 0);
const fmt = (n: number) => n.toLocaleString("en-US");
---

<Base title="home" active="home">
  <!-- the landscape is the front door: a compact title block, then the 3-D map
       filling the rest of the first viewport. -->
  <section class="hero">
    <div class="hero-top">
      <p class="eyebrow reveal">macro narrative dynamics</p>
      <h1 class="hero-title reveal">how macro narratives rise and fade.</h1>
      <p class="hero-thesis reveal">
        fifteen years of institutional writing — the Fed, IMF, BIS, NBER and
        their peers — clustered into narratives and mapped: every point below
        is one story, placed among its nearest neighbors.
      </p>
    </div>

    {hasMap && (
      <>
        <div id="map" class="map3d reveal" data-base={base}></div>
        <script id="map-data" type="application/json" set:html={JSON.stringify(entries)}></script>
        <p class="map-key reveal">
          color is the life-cycle stage —
          <span style="color:var(--growth)">growing</span>,
          <span style="color:var(--stable)">stable</span>,
          <span style="color:var(--decay)">fading</span>,
          <span style="color:var(--dormant)">dormant</span> —
          size is the volume written.
          <span class="map-hint">drag orbits · scroll zooms · click opens</span>
        </p>
      </>
    )}

    <div class="hero-foot reveal">
      <div class="hero-stats">
        <div><span class="num">{fmt(index.n_narratives)}</span><span class="lbl">narratives</span></div>
        <div><span class="num">{fmt(totalArticles)}</span><span class="lbl">articles</span></div>
        <div><span class="num">12</span><span class="lbl">feeds</span></div>
        <div><span class="num">2010</span><span class="lbl">tracked since</span></div>
      </div>
      <div class="hero-cta">
        <a href={`${base}/narratives`}>browse all narratives →</a>
        <a href={`${base}/emerging`}>see what's emerging →</a>
      </div>
    </div>
  </section>

  <script>
    import { mountMap3d } from "@lib/chart";
    const el = document.getElementById("map");
    const dataEl = document.getElementById("map-data");
    if (el && dataEl) {
      const pts = JSON.parse(dataEl.textContent).filter((d) => d.umap_xyz || d.umap_xy);
      mountMap3d(el, pts, el.dataset.base || "");
    }
  </script>
</Base>

<style>
  /* one viewport-height column (below the 64px sticky header and main's
     2.4rem top padding): title block on top, map filling the remainder, stat
     strip closing the first screen. */
  .hero {
    display: flex;
    flex-direction: column;
    min-height: calc(100svh - 64px - 2.4rem);
    padding: 0 0 1.2rem;
  }
  .hero .eyebrow { padding-left: 0.1em; }
  .hero-title {
    font-size: clamp(1.9rem, 3.6vw, 2.9rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0.3rem 0 0.7rem;
  }
  .hero-thesis {
    max-width: 72ch;
    font-size: var(--fs-lede);
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
  }

  .map3d {
    flex: 1;
    width: 100%;
    min-height: 320px;
    margin: 0.6rem 0 0;
    cursor: grab;
  }
  .map3d:active { cursor: grabbing; }
  .map-key {
    margin: 0.2rem 0 0;
    color: var(--muted);
    font-size: var(--fs-ui);
  }
  .map-key .map-hint {
    color: var(--faint);
    font-size: var(--fs-meta);
    display: inline-block;
    margin-left: 0.6rem;
  }

  .hero-foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.2rem 2.4rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }
  .hero-stats { display: flex; gap: 2.4rem; flex-wrap: wrap; }
  .hero-stats .num {
    display: block;
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    font-weight: 600;
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
  }
  .hero-stats .lbl { font-size: var(--fs-meta); color: var(--faint); letter-spacing: 0.03em; }
  .hero-cta {
    display: flex;
    gap: 1.6rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: var(--fs-body);
    font-weight: 600;
  }

  /* narrow screens: the text column is taller, so cap the map at a comfortable
     band instead of forcing a full-viewport column. */
  @media (max-width: 640px) {
    .hero { min-height: 0; }
    .map3d { min-height: 0; height: 56vh; }
    .hero-stats { gap: 1.2rem 1.8rem; }
    .hero-foot { flex-direction: column; align-items: flex-start; }
  }

  .hero .reveal:nth-of-type(1) { transition-delay: 0.05s; }
  .hero .reveal:nth-of-type(2) { transition-delay: 0.12s; }
  .hero .reveal:nth-of-type(3) { transition-delay: 0.2s; }
</style>
