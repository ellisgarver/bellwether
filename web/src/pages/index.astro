---
import Base from "../layouts/Base.astro";
import { loadIndex } from "@lib/data";

const index = loadIndex();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const entries = index.narratives;
const hasMap = entries.some((e) => e.umap_xyz || e.umap_xy);
const totalArticles = entries.reduce((s, e) => s + e.n_articles, 0);
const fmt = (n: number) => n.toLocaleString("en-US");
---

<Base title="home" active="home">
  <!-- the landscape is the front door: title, the headline numbers, the two
       entry points, then the 3-D map filling the rest of the first viewport. -->
  <section class="hero">
    <div class="hero-top">
      <h1 class="hero-title reveal">how macro narratives form, rise, and fade.</h1>
      <p class="hero-thesis reveal">
        years of institutional and academic writing from the Fed, IMF, BIS, NBER and
        their peers, clustered into narratives then analyzed and mapped. every point is
        a charted economic story, placed among its
        nearest neighbors.
      </p>
    </div>

    <div class="hero-band reveal">
      <div class="hero-stats">
        <div><span class="num">{fmt(index.n_narratives)}</span><span class="lbl">narratives</span></div>
        <div><span class="num">{fmt(totalArticles)}</span><span class="lbl">articles</span></div>
        <div><span class="num">12</span><span class="lbl">feeds</span></div>
        <div><span class="num">2010</span><span class="lbl">since</span></div>
      </div>
      <div class="hero-cta">
        <a href={`${base}/narratives`}>browse narratives →</a>
        <a href={`${base}/emerging`}>see what's emerging →</a>
        <a href={`${base}/directory`}>view the full directory →</a>
      </div>
    </div>

    {hasMap && (
      <>
        <div id="map" class="map3d reveal" data-base={base}></div>
        <script id="map-data" type="application/json" set:html={JSON.stringify(entries)}></script>
        <p class="map-key reveal">
          color is the life-cycle stage
          (<span style="color:var(--growth)">growth</span>,
          <span style="color:var(--stable)">stable</span>,
          <span style="color:var(--decay)">decay</span>,
          <span style="color:var(--dormant)">dormant</span>).
          size is the volume written. shape is the JEL economics field (X's are out of macro scope).
        </p>
      </>
    )}
  </section>

  <script>
    import { mountMap3d } from "@lib/chart";
    import { countUp } from "@lib/countup";
    countUp(document.querySelectorAll(".hero-stats .num"));
    const el = document.getElementById("map");
    const dataEl = document.getElementById("map-data");
    if (el && dataEl) {
      const pts = JSON.parse(dataEl.textContent).filter((d) => d.umap_xyz || d.umap_xy);
      mountMap3d(el, pts, el.dataset.base || "");
    }
  </script>
</Base>

<style>
  /* one viewport-height column (below the 64px sticky header and main's
     2.4rem top padding): title block, numbers, entry links, then the map
     filling the remainder with air on both sides of it. */
  .hero {
    display: flex;
    flex-direction: column;
    min-height: calc(100svh - 64px - 2.4rem);
    padding: 0 0 1.4rem;
  }
  .hero-title {
    font-size: var(--fs-title);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0.3rem 0 0.7rem;
  }
  .hero-thesis {
    font-size: var(--fs-lede);
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
  }

  .hero-band {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.2rem 2.4rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .hero-stats { display: flex; gap: 2.4rem; flex-wrap: wrap; }
  .hero-stats .num {
    display: block;
    font-size: var(--fs-stat);
    font-weight: 600;
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
  }
  .hero-stats .lbl { font-size: var(--fs-meta); color: var(--faint); letter-spacing: 0.03em; }
  .hero-cta {
    display: flex;
    gap: 1.6rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: var(--fs-body);
    font-weight: 600;
  }

  /* the map keeps the text column's width but gets a tall stage of its own;
     the hero may run past the first viewport to give it room. */
  .map3d {
    flex: 1;
    width: 100%;
    min-height: clamp(460px, 62vh, 720px);
    margin: 1.8rem 0 1rem;
    cursor: grab;
  }
  .map3d:active { cursor: grabbing; }
  .map-key {
    margin: 0;
    color: var(--muted);
    font-size: var(--fs-ui);
  }

  /* narrow screens: the text column is taller, so cap the map at a comfortable
     band instead of forcing a full-viewport column. */
  @media (max-width: 640px) {
    .hero { min-height: 0; }
    .map3d { min-height: 0; height: 56vh; margin: 1.4rem 0 0.8rem; }
    .hero-stats { gap: 1.2rem 1.8rem; }
    .hero-band { flex-direction: column; align-items: flex-start; }
  }

  .hero .reveal:nth-of-type(1) { transition-delay: 0.05s; }
  .hero .reveal:nth-of-type(2) { transition-delay: 0.12s; }
</style>
