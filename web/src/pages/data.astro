---
import Base from "../layouts/Base.astro";
import { loadIndex, loadNarrative, JEL_NAME } from "@lib/data";

const index = loadIndex();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// The "what is in the corpus" charts describe the FULL clustered corpus, not
// just the surfaced narratives. When the bake ships a full-corpus composition
// (ADR-076) we use it; older bakes fall back to aggregating the surfaced story
// cards, which only covers the charted subset.
const comp = index.corpus_composition ?? null;
const fullCorpus = !!(comp?.by_source || comp?.by_jel);
const totalArticles = index.narratives.reduce((s, e) => s + e.n_articles, 0);

// the four regional Federal Reserve banks are distinct source ids but roll up
// into one "regional Fed" feed for the chart (one of the twelve basis feeds).
const REGIONAL_FED = new Set(["fed_ny", "fed_sf", "fed_chicago", "fed_atlanta"]);
const groupSource = (s: string) => (REGIONAL_FED.has(s) ? "regional_fed" : s);

const sourceTotals = new Map<string, number>();
if (comp?.by_source) {
  for (const [src, n] of Object.entries(comp.by_source)) {
    const key = groupSource(src);
    sourceTotals.set(key, (sourceTotals.get(key) ?? 0) + n);
  }
} else {
  for (const e of index.narratives) {
    const card = loadNarrative(e.cluster_id).card;
    for (const [src, n] of card.source_mix) {
      const key = groupSource(src);
      sourceTotals.set(key, (sourceTotals.get(key) ?? 0) + n);
    }
  }
}
// source labels — acronyms / short institution names; unknown codes fall back to
// a de-underscored form so a new feed still renders sensibly.
const SOURCE_LABEL: Record<string, string> = {
  federalreserve: "Fed Board",
  regional_fed: "Regional Fed",
  imf: "IMF",
  bis: "BIS",
  cbo: "CBO",
  cea: "CEA",
  treasury_ofr: "OFR",
  brookings: "Brookings",
  piie: "PIIE",
  nber: "NBER",
  voxeu: "VoxEU",
  congressional: "Congress",
};
const sourceLabel = (s: string) => SOURCE_LABEL[s] ?? s.replace(/_/g, " ");
const sourceBars = [...sourceTotals.entries()]
  .map(([src, n]) => ({ label: sourceLabel(src), articles: n }))
  .sort((a, b) => a.articles - b.articles); // ascending: Plotly h-bars read bottom→top

// JEL-field totals (article-weighted), with in-scope flag for color.
const IN_SCOPE = new Set(["E", "F", "G", "H"]);
const jelTotals = new Map<string, number>();
if (comp?.by_jel) {
  for (const [code, n] of Object.entries(comp.by_jel)) {
    jelTotals.set(code, (jelTotals.get(code) ?? 0) + n);
  }
} else {
  for (const e of index.narratives) {
    const code = e.jel_code ?? "?";
    jelTotals.set(code, (jelTotals.get(code) ?? 0) + e.n_articles);
  }
}
const jelBars = [...jelTotals.entries()]
  .map(([code, n]) => ({
    code,
    name: JEL_NAME[code] ?? code,
    articles: n,
    in_scope: IN_SCOPE.has(code),
  }))
  .sort((a, b) => b.articles - a.articles);

// the basis set: one row per independent dimension of U.S. macro discourse,
// with the source(s) covering it.
const sources: [string, string][] = [
  [
    "U.S. monetary authority",
    "Federal Reserve Board: FOMC statements and minutes, speeches (including Jackson Hole), the Beige Book, FEDS Notes, the Monetary Policy Report, and the Financial Stability Report.",
  ],
  [
    "U.S. monetary research",
    "the regional Federal Reserve banks: New York (Liberty Street Economics, Staff Reports), San Francisco (Economic Letter, Working Papers, FedViews, Beige Book, Community Development), Chicago (research series, the president's speeches, business and economic-conditions surveys), and Atlanta (macroblog, working papers).",
  ],
  [
    "international macro authority",
    "the IMF: the World Economic Outlook, the Global Financial Stability Report, Finance & Development, working papers, and the IMF blog.",
  ],
  [
    "international central-bank network",
    "the BIS: the Quarterly Review, working papers, bulletins, and a curated set of central-bank speeches.",
  ],
  [
    "U.S. fiscal authority",
    "the CBO (cost estimates, the Budget and Economic Outlook, working papers, the Monthly Budget Review) and the Council of Economic Advisers (the Economic Report of the President).",
  ],
  [
    "U.S. financial-stability research",
    "the Treasury's Office of Financial Research: working papers and FSOC reports.",
  ],
  [
    "U.S. policy think tanks",
    "Brookings (Economic Studies and the Hutchins Center) and the Peterson Institute for International Economics.",
  ],
  [
    "academic work and commentary",
    "the NBER working-paper series and VoxEU, the CEPR's policy-column portal.",
  ],
  [
    "cross-cutting Q&A register",
    "Congressional testimony from the Treasury Secretary.",
  ],
];

const fmt = (n: number) => n.toLocaleString("en-US");
const floor = index.min_articles_to_fit;
const corpusStats: [string, string][] = [
  ...(index.n_articles_corpus
    ? ([[fmt(index.n_articles_corpus), "articles"]] as [string, string][])
    : []),
  ...(index.n_clusters_total
    ? ([[fmt(index.n_clusters_total), "clusters"]] as [string, string][])
    : []),
  ["12", "feeds"],
  ["2010", "since"],
];
const shownStats: [string, string][] = [
  [fmt(index.n_narratives), "narratives"],
  [fmt(totalArticles), "articles"],
  ...(index.median_article_words
    ? ([[fmt(index.median_article_words), "median words"]] as [string, string][])
    : []),
];
---

<Base title="data" active="data">
  <h1 class="reveal">the records behind bellwether</h1>
  <p class="lede reveal">
    a fixed, complete basis set of institutional and academic macroeconomic writing.
  </p>

  <div class="stat-band reveal">
    <div class="stat-group">
      <p class="stat-group-lbl">the full corpus</p>
      <div class="stat-row">
        {corpusStats.map(([num, lbl]) => (
          <div class="stat"><span class="num">{num}</span><span class="lbl">{lbl}</span></div>
        ))}
      </div>
    </div>
    <div class="stat-group">
      <p class="stat-group-lbl">explicitly analyzed here</p>
      <div class="stat-row">
        {shownStats.map(([num, lbl]) => (
          <div class="stat"><span class="num">{num}</span><span class="lbl">{lbl}</span></div>
        ))}
      </div>
    </div>
  </div>
  {floor && (
    <p class="muted reveal corpus-note">
      clustering keeps every topic;
      narratives with at least {floor} articles are charted. the rest are available in
      <a href={`${base}/directory`}>the full directory</a>.
    </p>
  )}

  <section class="section reveal">
    <h2>where the words come from</h2>
    <p>
      the source set is a fixed basis spanning every independent dimension of
      U.S. macro discourse, including the upstream writing of policymakers, researchers, and
      analysts. eight discourse dimensions plus a cross-cutting Q&A register, across
      twelve active source feeds, each carrying several document types (articles,
      speeches, reports). open a row for the underlying series:
    </p>
    <div class="feeds">
      {sources.map(([dim, src], i) => (
        <details class="feed">
          <summary class="feed-head">
            <span class="feed-n">{String(i + 1).padStart(2, "0")}</span>
            <span class="feed-dim">{dim}</span>
            <span class="feed-cue">+</span>
          </summary>
          <div class="feed-detail"><p>{src}</p></div>
        </details>
      ))}
    </div>
    <p>
      every article from every source enters the corpus; nothing is filtered by
      topic on the way in. the only ingest filters are the date window (2010
      onward) and near-duplicate removal: MinHash over character 5-grams,
      dropping documents above 0.85 Jaccard similarity (Broder 1997; Henzinger
      2006), keyed on both article URL and content. within-macro topical scope is
      decided later, in clustering.
    </p>
    <p class="muted">
      the financial press (WSJ, Bloomberg, FT, etc) sits downstream of
      these sources, tracked separately by volume overlay.
    </p>
  </section>

  <section class="section reveal">
    <h2>what is in the corpus</h2>
    <p>
      every clustered article across the {fullCorpus ? "full corpus" : "charted narratives"} counts
      toward one source and one JEL economics field. the left chart is how it splits
      across the twelve feeds; the right is how it splits across fields, with the
      macro-finance core (E, F, G, H) in accent and everything else flagged but still tracked.
    </p>
    <div class="charts">
      <figure class="chart-fig">
        <figcaption>articles by source</figcaption>
        <div id="src-chart" class="chart"></div>
      </figure>
      <figure class="chart-fig">
        <figcaption>articles by JEL field</figcaption>
        <div id="jel-chart" class="chart"></div>
      </figure>
    </div>
  </section>

  <script id="src-data" type="application/json" set:html={JSON.stringify(sourceBars)}></script>
  <script id="jel-data" type="application/json" set:html={JSON.stringify(jelBars)}></script>

  <script>
    import { Plotly, baseLayout, COL, CONFIG } from "@lib/chart";
    import { countUp } from "@lib/countup";
    countUp(document.querySelectorAll(".stat .num"));

    const read = (id: string) => {
      const el = document.getElementById(id);
      return el ? JSON.parse(el.textContent || "[]") : [];
    };

    const srcEl = document.getElementById("src-chart");
    const src = read("src-data");
    if (srcEl && src.length) {
      Plotly.newPlot(
        srcEl,
        [{
          type: "bar",
          orientation: "h",
          x: src.map((d: any) => d.articles),
          y: src.map((d: any) => d.label),
          marker: { color: COL.accent },
          hovertemplate: "%{x:,} articles<extra></extra>",
        }],
        baseLayout({
          margin: { l: 160, r: 18, t: 8, b: 36 },
          xaxis: { gridcolor: "rgba(226,220,207,0.6)", zeroline: false, tickformat: ",", fixedrange: true },
          yaxis: { automargin: true, fixedrange: true },
          bargap: 0.32,
        }),
        CONFIG,
      );
    }

    const jelEl = document.getElementById("jel-chart");
    const jel = read("jel-data");
    if (jelEl && jel.length) {
      // Align the JEL chart's top y-tick with the source chart's first (top)
      // bar label. The source chart is horizontal bars: its top bar sits half a
      // category slot below the plot-area top, so we push the JEL plot down by
      // that same half-slot (margin.t) and pin the JEL y-axis so its highest
      // tick lands exactly at the plot-area top.
      const SRC_T = 8, SRC_B = 36, CHART_H = 360;
      const halfSlot = src.length
        ? (CHART_H - SRC_T - SRC_B) / (2 * src.length)
        : 0;
      const niceStep = (rough: number) => {
        const mag = Math.pow(10, Math.floor(Math.log10(rough)));
        const norm = rough / mag;
        const f = norm <= 1 ? 1 : norm <= 2 ? 2 : norm <= 2.5 ? 2.5 : norm <= 5 ? 5 : 10;
        return f * mag;
      };
      const jelMax = Math.max(...jel.map((d: any) => d.articles));
      const step = niceStep(jelMax / 4);
      const niceMax = Math.ceil(jelMax / step) * step;
      Plotly.newPlot(
        jelEl,
        [{
          type: "bar",
          x: jel.map((d: any) => d.code),
          y: jel.map((d: any) => d.articles),
          marker: { color: jel.map((d: any) => (d.in_scope ? COL.accent : COL.faint)) },
          customdata: jel.map((d: any) => d.name),
          hovertemplate: "%{customdata} — %{y:,} articles<extra></extra>",
        }],
        baseLayout({
          margin: { l: 52, r: 12, t: Math.round(SRC_T + halfSlot), b: 40 },
          xaxis: { automargin: true, fixedrange: true },
          yaxis: {
            gridcolor: "rgba(226,220,207,0.6)", zeroline: false, tickformat: ",",
            range: [0, niceMax], dtick: step, fixedrange: true,
          },
          bargap: 0.4,
        }),
        CONFIG,
      );
    }
  </script>
</Base>

<style>
  /* note under the stat band — body size, matching the muted asides elsewhere. */
  .corpus-note { margin: var(--space-1) 0 0; }

  /* corpus stat band: two labeled groups — the full corpus vs what the site
     surfaces — with the same tabular figures as the home hero stats. */
  .stat-band {
    display: flex; flex-wrap: wrap; gap: 1.6rem 4.5rem;
    margin: var(--space-section) 0 0; padding: 1.2rem 0 0; border-top: 1px solid var(--line);
  }
  .stat-group-lbl {
    font-size: var(--fs-label); letter-spacing: 0.08em; color: var(--faint);
    margin: 0 0 0.7rem;
  }
  .stat-row { display: flex; flex-wrap: wrap; gap: 1.2rem 2.6rem; }
  .stat .num {
    display: block; font-size: var(--fs-stat); font-weight: 600; line-height: 1;
    font-variant-numeric: tabular-nums; color: var(--ink);
  }
  .stat .lbl { font-size: var(--fs-meta); color: var(--faint); letter-spacing: 0.03em; }

  /* corpus feeds: a row table where each row discloses its sources on click/tap
     (native <details> so it works with mouse, touch, and keyboard alike). */
  .feeds { margin: 1rem 0 1.4rem; }
  .feed { border-bottom: 1px solid var(--line-soft); transition: background 0.2s var(--ease); }
  .feed:hover { background: var(--paper-2); }
  .feed-head {
    display: grid; grid-template-columns: 2.4rem 1fr auto; align-items: center;
    gap: 0.9rem; padding: 0.8rem 0.5rem; cursor: pointer; list-style: none;
  }
  .feed-head::-webkit-details-marker { display: none; }
  .feed-n { color: var(--faint); font-variant-numeric: tabular-nums; font-size: var(--fs-meta); }
  .feed-dim { font-weight: 600; color: var(--ink); }
  .feed-cue {
    color: var(--accent); font-weight: 600; font-size: var(--fs-lede); line-height: 1;
    transition: transform 0.3s var(--ease), color 0.2s var(--ease);
  }
  .feed[open] .feed-cue { transform: rotate(45deg); color: var(--accent-bright); }
  .feed-detail p {
    margin: 0; padding: 0.1rem 0.5rem 0.9rem 3.8rem;
    color: var(--muted); font-size: var(--fs-ui);
  }

  /* corpus breakdown: two charts side by side, stacking on narrow screens. */
  .charts {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.6rem 2.2rem;
    margin: 1.6rem 0 0.4rem;
    /* top-align the two figures so both plots start at the same height; their
       bottoms may differ (the JEL chart's angled field labels run lower). */
    align-items: start;
  }
  .chart-fig { margin: 0; }
  .chart-fig figcaption {
    font-size: var(--fs-meta); color: var(--faint); letter-spacing: 0.03em;
    margin: 0 0 0.5rem;
  }
  .chart { width: 100%; height: 360px; }
  @media (max-width: 720px) {
    .charts { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .feed-cue { transition: none; }
  }
</style>
