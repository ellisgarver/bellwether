---
import Base from "../layouts/Base.astro";
import { loadIndex } from "@lib/data";
const index = loadIndex();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const repo = "https://github.com/ellisgarver/macro-narrative-dynamics";
const example =
  index.narratives.find((e) => e.label.toLowerCase().includes("inflation")) ??
  index.narratives[0];

// the basis set (ADR-020): one row per independent dimension of U.S. macro
// discourse, with the source(s) covering it.
const sources: [string, string][] = [
  [
    "U.S. monetary authority",
    "Federal Reserve Board — FOMC statements and minutes, speeches (including Jackson Hole), the Beige Book, FEDS Notes, the Monetary Policy Report, and the Financial Stability Report.",
  ],
  [
    "U.S. monetary research",
    "the regional Federal Reserve banks — New York (Liberty Street Economics, Staff Reports), San Francisco (Economic Letter, Working Papers, FedViews, Beige Book, Community Development), Chicago (research series, the president's speeches, business and economic-conditions surveys), and Atlanta (macroblog, working papers).",
  ],
  [
    "international macro authority",
    "the IMF — the World Economic Outlook, the Global Financial Stability Report, Finance & Development, working papers, and the IMF blog.",
  ],
  [
    "international central-bank network",
    "the BIS — the Quarterly Review, working papers, bulletins, and a curated set of central-bank speeches.",
  ],
  [
    "U.S. fiscal authority",
    "the CBO (cost estimates, the Budget and Economic Outlook, working papers, the Monthly Budget Review) and the Council of Economic Advisers (the Economic Report of the President).",
  ],
  [
    "U.S. financial-stability research",
    "the Treasury's Office of Financial Research — working papers and FSOC reports.",
  ],
  [
    "U.S. policy think tanks",
    "Brookings (Economic Studies and the Hutchins Center) and the Peterson Institute for International Economics.",
  ],
  [
    "academic work and commentary",
    "the NBER working-paper series and VoxEU, the CEPR's policy-column portal.",
  ],
  [
    "cross-cutting Q&A register",
    "Congressional testimony from the Treasury Secretary.",
  ],
];
---

<Base title="guide + research" active="about">
  <p class="eyebrow reveal">guide + research</p>
  <h1 class="reveal">reading narratives as epidemics</h1>
  <p class="lede reveal">
    more on how the tool actually works, the research it is built on, and the project inspiration.
  </p>

  <a class="part reveal" href="#guide">the guide — how to read the tool <span class="arrow">↓</span></a>

  <section class="section reveal" id="guide">
    <p class="eyebrow">1 · the corpus</p>
    <h2>where the words come from</h2>
    <p>
      the source set is fixed. it is purposefully built as a basis set: the smallest group of
      sources that covers every independent dimension of U.S. macro discourse, with
      nothing redundant. these are the upstream sources, narratives from
      policymakers, researchers and analysts. nine dimensions, twelve active feeds, each with varying data types — hover a row for more information:
    </p>
    <div class="feeds">
      {sources.map(([dim, src], i) => (
        <div class="feed">
          <div class="feed-head">
            <span class="feed-n">{String(i + 1).padStart(2, "0")}</span>
            <span class="feed-dim">{dim}</span>
            <span class="feed-cue">+</span>
          </div>
          <div class="feed-detail"><p>{src}</p></div>
        </div>
      ))}
    </div>
    <p>
      every article from every source enters the corpus; nothing is filtered by
      topic on the way in. the only ingest filters are the date window (2010 to
      today) and the removal of near-duplicate documents. within-macro topical scope is decided in clustering.
    </p>
    <p class="muted">
      financial press itself (WSJ, Bloomberg, FT, etc) is downstream, its text is not ingested; butrth its volume is tracked separately as an overlay.
    </p>
  </section>

  <section class="section reveal">
    <p class="eyebrow">2 · clustering</p>
    <h2>from articles to narratives</h2>

    <figure class="pipeline reveal">
      <div class="pipe">
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <rect x="6" y="3" width="16" height="22" rx="1.5" />
              <line x1="9" y1="9" x2="19" y2="9" /><line x1="9" y1="13" x2="19" y2="13" />
              <line x1="9" y1="17" x2="16" y2="17" />
            </svg>
          </span>
          <span class="ptext"><strong>articles</strong>every document, whole</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <rect x="6" y="3" width="16" height="22" rx="1.5" />
              <line class="cut" x1="6" y1="11" x2="22" y2="11" />
              <line class="cut" x1="6" y1="18" x2="22" y2="18" />
            </svg>
          </span>
          <span class="ptext"><strong>passages</strong>≈512-token chunks</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <circle cx="8" cy="9" r="1.6" /><circle cx="15" cy="6" r="1.6" />
              <circle cx="21" cy="11" r="1.6" /><circle cx="11" cy="16" r="1.6" />
              <circle cx="19" cy="19" r="1.6" /><circle cx="7" cy="22" r="1.6" />
            </svg>
          </span>
          <span class="ptext"><strong>embeddings</strong>Qwen3 vectors</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <circle class="hull" cx="9" cy="10" r="6" />
              <circle class="hull" cx="19" cy="18" r="5.5" />
              <circle cx="7" cy="9" r="1.4" /><circle cx="11" cy="11" r="1.4" /><circle cx="9" cy="13" r="1.4" />
              <circle cx="18" cy="17" r="1.4" /><circle cx="21" cy="19" r="1.4" />
            </svg>
          </span>
          <span class="ptext"><strong>clusters</strong>UMAP + HDBSCAN</span>
        </div>
        <div class="pstep">
          <span class="pglyph">
            <svg viewBox="0 0 28 28" aria-hidden="true">
              <path d="M5 9 h11 l6 5 -6 5 H5 z" />
              <circle class="tag-eye" cx="9" cy="14" r="1.4" />
            </svg>
          </span>
          <span class="ptext"><strong>label + scope</strong>c-TF-IDF, JEL</span>
        </div>
      </div>
    </figure>

    <p>
      each article is split into passages of roughly 512 tokens or less — the
      retrieval unit from the BEIR benchmark — so long reports are read in
      coherent pieces not averaged into mush. each passage is transformed into
      a high-dimensional vector by a sentence-embedding model (Qwen3-Embedding),
      where geometric closeness mimics semantic closeness: two passages with the
      same argument land near each other.
    </p>
    <p>
      those vectors are clustered with BERTopic, which reduces them to a lower
      dimension (UMAP), finds dense regions of related passages (HDBSCAN), and then
      names each region by the terms that are frequent within but rare elsewhere
      (a class-based TF-IDF). density-based clustering leaves passages belonging to no clear group as outliers, and each
      surviving group is a narrative candidate.
    </p>
    <p>
      scope is decided after clustering with each cluster matched to the
      standard JEL economics
      taxonomy published by the American Economic Association. this is done by comparing the
      cluster's centre to a prototype vector for each JEL field and taking the
      nearest one. clusters in the macro-finance fields — JEL E (macroeconomics and
      monetary), F (international), G (financial) and H (public and fiscal) — drive
      the main dynamics; clusters found outside those fields are still shown, but greyed out
      and left out of the modelling.
    </p>
  </section>

  <section class="section reveal">
    <p class="eyebrow">3 · the model</p>
    <h2>four lenses on one curve</h2>
    <p>
      counting a narrative's articles per week gives a volume curve — a time series
      of how loud the story is. that count is then adjusted for how much the whole
      corpus published that day, so a story doesn't look like it's growing just because
      coverage overall grew. four lenses are applied to that adjusted curve and shown
      side by side. each encodes a different assumption about how a story spreads:
    </p>
    <div class="lenses">
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,42 C40,42 44,30 60,24 C76,18 80,6 114,6" />
        </svg>
        <div>
          <strong>logistic growth</strong> <span class="cite">(Verhulst, 1838)</span>
          <p>a characteristic S-shaped rise to a saturation ceiling, governed by a growth rate and a carrying capacity.</p>
        </div>
      </div>
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,44 C36,44 46,6 60,6 C74,6 84,44 114,44" />
        </svg>
        <div>
          <strong>SIR epidemic</strong> <span class="cite">(Kermack &amp; McKendrick, 1927)</span>
          <p>splits the population into susceptible, infected, and recovered with an infection rate β and a recovery rate γ; their ratio β/γ is R₀.</p>
        </div>
      </div>
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,44 C16,44 20,30 28,30 C36,30 38,40 48,40 C64,40 74,8 92,8 C104,8 110,38 114,42" />
        </svg>
        <div>
          <strong>Bass diffusion</strong> <span class="cite">(Bass, 1969)</span>
          <p>shows adoption via innovators (who initiate the story) and imitators (who pick it up from others), with a coefficient for each.</p>
        </div>
      </div>
      <div class="lens-card">
        <svg class="mini" viewBox="0 0 120 48" aria-hidden="true">
          <path pathLength="1" d="M6,44 C36,44 46,8 60,8 C74,8 84,44 114,44" />
          <line class="gd" x1="60" y1="8" x2="60" y2="44" />
          <circle class="pk" cx="60" cy="8" r="3" />
        </svg>
        <div>
          <strong>shape facts</strong>
          <p>model-free readings taken straight from a view of the true curve: time to peak, total volume, number of distinct waves.</p>
        </div>
      </div>
    </div>
    <p>
      each fit is done with Bayesian inference (PyMC). instead of a single
      best-guess parameter, the fit returns a posterior distribution, so every
      estimate additionally carries a confidence interval. the lenses are
      compared with AICc, a small-sample penalised likelihood — providing a
      diagnostic of which lens fits best but does not rule out any narrative as a valid progression.
    </p>
    <p>the number borrowed from epidemiology is R₀, the reproduction number, and it does the staging:</p>
    <ul class="r0">
      <li class="g"><span class="k">R₀ &gt; 1</span><span>each wave seeds more than one successor; growth</span></li>
      <li class="d"><span class="k">R₀ &lt; 1</span><span>each wave seeds less than one successor; decay</span></li>
      <li class="z"><span class="k">no fit</span><span>no stable parameters recover; dormant</span></li>
    </ul>
  </section>

  <section class="section reveal">
    <p class="eyebrow">4 · the page</p>
    <h2>reading a narrative</h2>
    <p>
      take <a href={`${base}/narratives/${example.cluster_id}`}>{example.label}</a> for example. the
      bars are its weekly article volume, and the line is the selected lens, switched
      via tabs. the press overlay shows when premium press media picked the story up,
      usually but not strictly later than the institutional sources. note that each overlay is rescaled onto
      the same axis as the volume bars to compare directional rise and fall, timing, and magnitude of change.
    </p>
    <p>
      the markets overlay compares the narrative against a standard series such as the VIX or
      the 10-year yield. underneath sits a bidirectional Granger causality test:
      it sweeps over a range of lags and checks, in both directions, to observe whether past
      values of one series help predict the other better than the series predicts
      itself, and reports the lag with the strongest signal. this provides a statement about
      temporal precedence — whether the discourse moved before or after the market. a story can lead a market even without driving it.
    </p>
    <p>
      top articles for each narratie are provided for context. the similar-narratives list ranks neighbours by three complementary measures:
      semantic closeness (cosine distance between cluster centers in embedding
      space), lexical overlap (shared distinctive terms), and a correlation of the
      two volume curves over time. a narrative that is close on all three is a near
      sibling.
    </p>
  </section>

  <a class="part reveal" href="#research">the research — what it is built on <span class="arrow">↓</span></a>

  <section class="section reveal" id="research">
    <p class="eyebrow">the idea</p>
    <h2>contagious economic stories</h2>

    <figure class="idea-graphic reveal">
      <svg class="contagion" viewBox="0 0 320 130" aria-hidden="true">
        <line class="edge" x1="60" y1="65" x2="120" y2="30" />
        <line class="edge" x1="60" y1="65" x2="130" y2="100" />
        <line class="edge" x1="120" y1="30" x2="200" y2="42" />
        <line class="edge" x1="130" y1="100" x2="210" y2="92" />
        <line class="edge" x1="200" y1="42" x2="270" y2="65" />
        <line class="edge" x1="210" y1="92" x2="270" y2="65" />
        <circle class="node n-s" cx="60" cy="65" r="9" />
        <circle class="node n-a" cx="120" cy="30" r="8" />
        <circle class="node n-b" cx="130" cy="100" r="8" />
        <circle class="node n-c" cx="200" cy="42" r="8" />
        <circle class="node n-d" cx="210" cy="92" r="8" />
        <circle class="node n-e" cx="270" cy="65" r="9" />
      </svg>
      <figcaption class="sir-key">
        <span><i class="dot s"></i>susceptible</span>
        <span><i class="dot i"></i>infected</span>
        <span><i class="dot r"></i>recovered</span>
      </figcaption>
    </figure>

    <p>
      this project is framed around Robert Shiller's <em>Narrative Economics</em> (2017 AEA
      presidential address; 2019 book): economic stories spread through a population
      the way contagious diseases do — a story is "caught" from exposure, carried for
      a while, and eventually dropped, and its prevalence over time traces the same
      rise-and-fall shape as an outbreak. the project seeks to quantify this analogy. 
    </p>
    <p>
      Shiller maps cleanly onto SIR compartments: people who have not yet
      encountered a story are <em>susceptible</em>, those actively repeating it are
      <em>infected</em>, and those who have moved on are <em>recovered</em>. the same
      mechanics that determine whether a disease takes off also determine whether a story does. specifically, 
      we measure the lifecycle half of Shiller's claim —
      emergence, growth, peak, decay — using century-old models economists
      and epidemiologists share, applied to the volume of institutional
      macro writing rather than to surveys or social media.
    </p>
  </section>

  <section class="section reveal">
    <p class="eyebrow">the grounding</p>
    <h2>field-standard, not hand-tuned</h2>
    <p>
      results are credible because nothing is tuned
      to make the output look better. every parameter in the pipeline is either a
      published library default or a value taken from the primary literature with a
      citation. where no field-accepted anchor existed, that knob was removed
      rather than guessed or predicted. there are no sensitivity sweeps, no thresholds nudged
      toward a nicer-looking chart, and crucially, nothing is ever adjusted to
      improve how well the system recovers known events. with no
      train/test split, no-tuning rule keeps the exercise honest.
    </p>
    <p class="muted">
      see the full methodology, with citations in
      <a href={`${repo}/blob/main/docs/METHODOLOGY.md`} target="_blank" rel="noopener">METHODOLOGY.md</a>
      from the repository.
    </p>
  </section>

  <a class="part reveal" href="#purpose">the purpose — why it was built <span class="arrow">↓</span></a>

  <section class="section reveal" id="purpose">
    <p class="eyebrow">the goal</p>
    <h2>a tool for reading the recent past</h2>
    <p>
      built as an educational and historical-analysis tool,
      walk back through fifteen years of macro-financial discourse and watch how
      specific stories — the 2013 taper tantrum, the transitory-inflation debate,
      the 2023 soft-landing turn — emerged, took hold, peaked and faded, in the
      words of the institutions that shaped them. or just keep an eye out for how the most
      recent stories are turning out.
    </p>
    <p>
      the aim is to make an abstract idea more concrete. Shiller's claim that narratives
      spread like contagions is easy to state and hard to feel. here you can see the
      curve, switch the lens, line it up against the markets, and judge the analogy
      for yourself. free and reproducible.

<style>
  /* part labels behave like the homepage scroll cues: an accent link with a down
     arrow that jumps to the start of that section and nudges on hover. */
  .part {
    display: inline-flex; align-items: center; gap: 0.45rem;
    margin: var(--space-5) 0 0;
    font-size: var(--fs-ui);
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 600;
  }
  .part:hover { color: var(--accent-bright); }
  .part .arrow { transition: transform 0.25s var(--ease); }
  .part:hover .arrow { transform: translateY(3px); }
  /* no hairline under the cue; the jump lands the section's top flush under the
     64px sticky header so the cue itself scrolls out of view, with a small top
     pad so the eyebrow isn't crammed against the header. */
  .part + .section { border-top: none; }
  #guide, #research, #purpose { scroll-margin-top: 64px; padding-top: 1.1rem; }

  @keyframes draw { from { stroke-dashoffset: 1; } to { stroke-dashoffset: 0; } }

  /* clustering pipeline: a left-to-right flow of glyph steps. each glyph lights up
     in sequence so the eye reads the data moving through the stages. */
  .pipeline { margin: 2.6rem 0; padding: 0.4rem 0; }
  .pipe { display: flex; align-items: stretch; gap: 0.4rem; flex-wrap: wrap; }
  .pstep {
    flex: 1 1 0; min-width: 92px;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 0.5rem; position: relative;
  }
  /* connector arrow between steps */
  .pstep:not(:last-child)::after {
    content: "→"; position: absolute; top: 22px; right: -0.55rem;
    color: var(--faint); font-size: var(--fs-ui); line-height: 1;
  }
  .pglyph {
    display: grid; place-items: center; width: 48px; height: 48px; border-radius: 10px;
    background: var(--paper-2); border: 1px solid var(--line);
    animation: flowpulse 5s ease-in-out infinite;
  }
  .pglyph svg { width: 28px; height: 28px; }
  .pglyph svg :is(rect, line, circle, path) {
    fill: none; stroke: var(--accent); stroke-width: 1.6;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .pglyph svg circle:not(.hull):not(.tag-eye) { fill: var(--accent); stroke: none; }
  .pglyph svg .hull { stroke: var(--line); stroke-dasharray: 2 2.5; }
  .pglyph svg .cut { stroke: var(--ember); stroke-dasharray: 2 2; }
  .pglyph svg .tag-eye { fill: var(--paper-2); stroke: var(--accent); stroke-width: 1.4; }
  .pstep:nth-child(1) .pglyph { animation-delay: 0s; }
  .pstep:nth-child(2) .pglyph { animation-delay: 0.5s; }
  .pstep:nth-child(3) .pglyph { animation-delay: 1s; }
  .pstep:nth-child(4) .pglyph { animation-delay: 1.5s; }
  .pstep:nth-child(5) .pglyph { animation-delay: 2s; }
  @keyframes flowpulse {
    0%, 100% { background: var(--paper-2); border-color: var(--line); }
    50% { background: color-mix(in srgb, var(--accent) 13%, var(--paper)); border-color: var(--accent); }
  }
  .ptext { display: flex; flex-direction: column; font-size: var(--fs-meta); color: var(--faint); line-height: 1.3; }
  .ptext strong { color: var(--ink); font-size: var(--fs-ui); font-weight: 600; }
  .pipeline figcaption { color: var(--faint); font-size: var(--fs-meta); margin-top: 0.9rem; }
  @media (max-width: 560px) {
    .pipe { flex-direction: column; align-items: stretch; gap: 0.7rem; }
    .pstep { flex-direction: row; gap: 0.8rem; text-align: left; }
    .pstep:not(:last-child)::after { content: "↓"; top: auto; right: auto; left: 23px; bottom: -0.65rem; }
    .ptext { align-items: flex-start; }
  }

  /* corpus feeds: a row table where each row reveals its sources on hover */
  .feeds { margin: 1rem 0 1.4rem; }
  .feed { border-bottom: 1px solid var(--line-soft); transition: background 0.2s var(--ease); }
  .feed:hover { background: var(--paper-2); }
  .feed-head {
    display: grid; grid-template-columns: 2.4rem 1fr auto; align-items: center;
    gap: 0.9rem; padding: 0.8rem 0.5rem; cursor: default;
  }
  .feed-n { color: var(--faint); font-variant-numeric: tabular-nums; font-size: var(--fs-meta); }
  .feed-dim { font-weight: 600; color: var(--ink); }
  .feed-cue {
    color: var(--accent); font-weight: 600; font-size: var(--fs-lede); line-height: 1;
    transition: transform 0.3s var(--ease), color 0.2s var(--ease);
  }
  .feed:hover .feed-cue { transform: rotate(45deg); color: var(--accent-bright); }
  .feed-detail {
    max-height: 0; overflow: hidden; opacity: 0;
    transition: max-height 0.4s var(--ease), opacity 0.3s var(--ease);
  }
  .feed:hover .feed-detail { max-height: 12rem; opacity: 1; }
  .feed-detail p {
    margin: 0; padding: 0 0.5rem 0.9rem 3.3rem;
    color: var(--muted); font-size: var(--fs-ui); max-width: var(--measure);
  }
  @media (prefers-reduced-motion: reduce) {
    .feed-detail { transition: none; }
  }
  /* lenses: a 2×2 grid of cards, each with a mini sketch of its curve shape that
     redraws on hover. */
  .lenses {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem 2.2rem;
    margin: 1.6rem auto; max-width: 54rem;
  }
  .lens-card {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 0.45rem; padding: 1.3rem 0.6rem; border-top: 1px solid var(--line-soft);
  }
  .mini { width: 168px; height: 56px; display: block; }
  .mini path { fill: none; stroke: var(--accent); stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; }
  .mini .pk { fill: var(--ember); stroke: none; }
  .mini .gd { stroke: var(--line); stroke-width: 1; stroke-dasharray: 2 3; }
  .lens-card:hover .mini path { stroke-dasharray: 1; animation: draw 0.9s var(--ease) forwards; }
  .lens-card > div { max-width: 32ch; }
  .lens-card .cite { color: var(--faint); font-size: var(--fs-meta); font-weight: 400; }
  .lens-card p { margin: 0.3rem 0 0; color: var(--muted); font-size: var(--fs-ui); }

  /* R₀ states as stage-coloured rows: a fixed key column + description, uniform
     rounded full-width bars so the block reads as a finished table. */
  .r0 { list-style: none; padding: 0; margin: 1.2rem 0; width: fit-content; max-width: var(--measure); display: flex; flex-direction: column; gap: 0.5rem; }
  .r0 li {
    display: grid; grid-template-columns: 6rem 1fr; align-items: center; gap: 1rem;
    padding: 0.7rem 3.5rem 0.7rem 1rem; border-radius: 8px;
    background: var(--paper-2); border-left: 3px solid var(--line); color: var(--muted);
  }
  .r0 .k {
    justify-self: start; font-weight: 700; font-variant-numeric: tabular-nums;
    white-space: nowrap; padding: 0.1rem 0.55rem; border-radius: 999px; font-size: var(--fs-ui);
  }
  .r0 .g { border-left-color: var(--growth); }
  .r0 .g .k { color: var(--growth); background: color-mix(in srgb, var(--growth) 14%, var(--paper)); }
  .r0 .d { border-left-color: var(--decay); }
