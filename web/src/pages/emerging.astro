---
import Base from "../layouts/Base.astro";
import NarrativeCard from "@components/NarrativeCard.astro";
import { loadDirectory, loadIndex, loadNarrative, displayName } from "@lib/data";

const index = loadIndex();
const hasInScope = index.narratives.some((e) => e.in_scope);
const floor = index.min_articles_to_fit ?? 42;

// Forming (ADR-071): sub-floor clusters with recent onsets, from the directory
// artifact — the true frontier, since a brand-new story rarely has enough
// articles to clear the charting floor yet. Newest onset first.
const forming = (loadDirectory()?.clusters ?? [])
  .filter((c) => c.forming)
  .sort((a, b) => (b.date_range?.[0] ?? "").localeCompare(a.date_range?.[0] ?? ""));
const formingName = (c: (typeof forming)[number]) =>
  c.label_human || (c.terms ?? []).slice(0, 5).join(", ") ||
  c.label.replace(/^-?\d+_/, "").split("_").join(", ");

function spark(values: number[], n = 44): number[] {
  if (values.length <= n) return values;
  const out: number[] = [];
  const step = values.length / n;
  for (let i = 0; i < n; i++) {
    const a = Math.floor(i * step);
    const b = Math.floor((i + 1) * step);
    const slice = values.slice(a, Math.max(a + 1, b));
    out.push(slice.reduce((s, v) => s + v, 0) / slice.length);
  }
  return out;
}

// Two distinct signals, shown side by side and never merged (ADR-057/064):
//  1. institutional onset — a narrative first appeared within the recency window
//     of the corpus frontier (is_emerging).
//  2. press heating — the press is spiking on a narrative we already track
//     (is_press_heating), from live Media Cloud attention-share.
// A narrative can carry either, both, or neither; keeping them separate lets the
// reader tell "our sources just started on this" from "the press is spiking on it".
const need = index.narratives.filter((e) => e.is_emerging || e.is_press_heating);
const narrs = need.map((e) => loadNarrative(e.cluster_id));
const byId = (id: number) => narrs.find((n) => n.cluster_id === id)!;
const speed = (n: ReturnType<typeof loadNarrative>): number => {
  const s = n.stage_detail?.trend_slope;
  return typeof s === "number" ? s : -Infinity;
};
const emerging = index.narratives
  .filter((e) => e.is_emerging)
  .sort((a, b) => speed(byId(b.cluster_id)) - speed(byId(a.cluster_id)));
// heating ordered by the press z-score (how far above baseline), strongest first.
const heatZ = (id: number) => byId(id).mediacloud?.press_heating?.z ?? -Infinity;
const heating = index.narratives
  .filter((e) => e.is_press_heating)
  .sort((a, b) => heatZ(b.cluster_id) - heatZ(a.cluster_id));
const sparks: Record<number, number[]> = Object.fromEntries(
  narrs.map((n) => [n.cluster_id, spark(n.volume.values)]),
);
// heating threshold shown in the lede (same k for every narrative in a build).
const kSigma = heating.length
  ? (byId(heating[0].cluster_id).mediacloud?.press_heating?.k ?? 2)
  : 2;
---

<Base title="emerging" active="emerging">
  <p class="eyebrow reveal">the frontier</p>
  <h1 class="reveal">emerging narratives</h1>
  <p class="lede reveal">
    narratives that first appeared within four weeks of the corpus frontier,
    ordered by how fast they are rising.
  </p>

  <div class="toolbar reveal">
    <input id="e-search" type="search" placeholder="filter by name or term…" />
    <label class="toggle"><input type="checkbox" id="e-growth" checked /> growth</label>
    <label class="toggle"><input type="checkbox" id="e-stable" checked /> stable</label>
    <label class="toggle"><input type="checkbox" id="e-decay" checked /> decay</label>
    <label class="toggle"><input type="checkbox" id="e-dormant" checked /> dormant</label>
    {hasInScope && (
      <label class="toggle scope"><input type="checkbox" id="e-scope" checked /> macro scope only</label>
    )}
  </div>

  <div class="grid reveal" id="e-gallery">
    {emerging.map((e) => (
      <div class="card-wrap" data-label={(displayName(e) + " " + e.label).toLowerCase()}
        data-terms={e.top_terms.join(" ").toLowerCase()}
        data-stage={e.stage}
        data-scope={e.in_scope ? "in" : "out"}>
        <NarrativeCard entry={e} spark={sparks[e.cluster_id]} />
      </div>
    ))}
  </div>
  <p id="e-empty" class={`muted${emerging.length ? " hidden" : ""}`}>
    {emerging.length ? "no narratives match that filter." : "none in the current window."}
  </p>
  <nav id="e-pager" class="pager" aria-label="emerging pages"></nav>

  {forming.length > 0 && (
    <section class="forming reveal">
      <p class="eyebrow">below the floor</p>
      <h2>forming</h2>
      <p class="lede">
        new clusters that appeared within the last four weeks but haven't reached
        the {floor}-article floor for a full page. they graduate to charted
        narratives as they grow.
      </p>
      <div class="forming-rows">
        {forming.map((c) => (
          <div class="forming-row">
            <span class="forming-name">{formingName(c)}</span>
            <span class="forming-meta">
              {c.n_articles} articles · since {c.date_range?.[0]}
            </span>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="heating reveal">
    <p class="eyebrow">a separate signal</p>
    <h2>heating in the press</h2>
    <p class="lede">
      tracked narratives whose recent broad press attention sits more than {kSigma}σ
      above their own yearly baseline (via Media Cloud). this signal is press-led,
      separate from when the institutional sources first pick a story up given above.
    </p>

    <div class="toolbar">
      <input id="h-search" type="search" placeholder="filter by name or term…" />
      <label class="toggle"><input type="checkbox" id="h-growth" checked /> growth</label>
      <label class="toggle"><input type="checkbox" id="h-stable" checked /> stable</label>
      <label class="toggle"><input type="checkbox" id="h-decay" checked /> decay</label>
      <label class="toggle"><input type="checkbox" id="h-dormant" checked /> dormant</label>
      {hasInScope && (
        <label class="toggle scope"><input type="checkbox" id="h-scope" checked /> macro scope only</label>
      )}
    </div>

    <div class="grid" id="h-gallery">
      {heating.map((e) => (
        <div class="card-wrap" data-label={(displayName(e) + " " + e.label).toLowerCase()}
          data-terms={e.top_terms.join(" ").toLowerCase()}
          data-stage={e.stage}
          data-scope={e.in_scope ? "in" : "out"}>
          <NarrativeCard entry={e} spark={sparks[e.cluster_id]} />
        </div>
      ))}
    </div>
    <p id="h-empty" class={`muted${heating.length ? " hidden" : ""}`}>
      {heating.length ? "no narratives match that filter." : "none right now."}
    </p>
    <nav id="h-pager" class="pager" aria-label="press-heating pages"></nav>
  </section>

  <script>
    import { setupCatalog } from "@lib/catalog";

    // Both sections carry the same filter bar as the narratives catalog; wire
    // each to its own controls by id prefix.
    function wire(prefix) {
      const $ = (id) => document.getElementById(`${prefix}-${id}`);
      const search = $("search");
      const gallery = $("gallery");
      if (!search || !gallery) return;
      const flags = {
        growth: $("growth"),
        stable: $("stable"),
        decay: $("decay"),
        dormant: $("dormant"),
      };
      const scope = $("scope");
      const catalog = setupCatalog({
        cards: [...gallery.querySelectorAll(".card-wrap")],
        empty: $("empty"),
        pager: $("pager"),
        scrollTo: gallery,
        matches(c) {
          const q = (search.value || "").trim().toLowerCase();
          const anyChecked = Object.values(flags).some((f) => f?.checked);
          const okText = !q || c.dataset.label.includes(q) || c.dataset.terms.includes(q);
          const okCat = !anyChecked || flags[c.dataset.stage]?.checked;
          const okScope = !scope?.checked || c.dataset.scope === "in";
          return okText && okCat && okScope;
        },
      });
      [search, ...Object.values(flags), scope].forEach((el) =>
        el?.addEventListener("input", () => catalog.refresh()),
      );
    }
    wire("e");
    wire("h");
  </script>
</Base>

<style>
  .toolbar {
    display: flex; gap: 1.2rem; flex-wrap: wrap; align-items: center;
    margin: 1.4rem 0 0.6rem; padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .toolbar input[type="search"] {
    flex: 1; min-width: 220px; padding: 0.55rem 0.2rem;
    border: none; border-bottom: 1px solid var(--line);
    background: transparent; font: inherit; color: var(--ink);
  }
  .toolbar input[type="search"]:focus {
    outline: none; border-bottom-color: var(--accent);
  }
  .heating, .forming {
    margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--line);
  }
  .heating h2, .forming h2 { margin: 0.2rem 0 0.4rem; }
  .heating .lede { margin-bottom: 0.2rem; }
  .forming .lede { margin-bottom: 1rem; }
  .forming-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 0.6rem 1.6rem; flex-wrap: wrap;
    padding: 0.55rem 0.2rem; border-bottom: 1px solid var(--line-soft);
  }
  .forming-name { color: var(--ink); font-weight: 600; }
  .forming-meta {
    color: var(--muted); font-size: var(--fs-meta);
    font-variant-numeric: tabular-nums; white-space: nowrap;
  }
</style>
