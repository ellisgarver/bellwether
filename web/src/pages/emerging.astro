---
import Base from "../layouts/Base.astro";
import NarrativeCard from "@components/NarrativeCard.astro";
import {
  CORPUS_HEATING,
  PRESS_HEATING,
  STAGE_COLOR,
  corpusHeating,
  pressHeating,
  loadDirectory,
  loadIndex,
  loadNarrative,
  displayName,
  type IndexEntry,
} from "@lib/data";

const index = loadIndex();
const hasInScope = index.narratives.some((e) => e.in_scope);

function spark(values: number[], n = 44): number[] {
  if (values.length <= n) return values;
  const out: number[] = [];
  const step = values.length / n;
  for (let i = 0; i < n; i++) {
    const a = Math.floor(i * step);
    const b = Math.floor((i + 1) * step);
    const slice = values.slice(a, Math.max(a + 1, b));
    out.push(slice.reduce((s, v) => s + v, 0) / slice.length);
  }
  return out;
}

// Two symmetric signals over the same quarterly window, shown side by side and
// never merged (ADR-057/064/074):
//  1. heating in the corpus — our own sources are writing about a narrative
//     markedly more than usual (recent window vs. its own yearly baseline).
//  2. heating in the press — the broad press is spiking on the same narrative,
//     from live Media Cloud attention-share.
// A narrative can carry either, both, or neither; keeping them separate lets the
// reader tell "institutions are turning to this" from "the press is spiking on it".

// Corpus frontier = latest last-active date across surfaced narratives — the
// same reference point the bake uses (ADR-059).
const frontierMs = Math.max(
  ...index.narratives.map((e) => (e.date_range ? Date.parse(e.date_range[1]) : 0)),
);

const narrs = new Map(index.narratives.map((e) => [e.cluster_id, loadNarrative(e.cluster_id)]));
const corpusHeat = index.narratives
  .map((e) => ({ e, heat: corpusHeating(narrs.get(e.cluster_id)!.volume, frontierMs) }))
  .filter((x) => x.heat !== null)
  .sort((a, b) => b.heat!.z - a.heat!.z);

// Sub-floor clusters with a recent onset that haven't yet crossed the article
// floor for a full narrative page (ADR-071).
const floor = index.min_articles_to_fit ?? 42;
const dir = loadDirectory();
const dirClusters = dir?.clusters ?? [];
const formingClusters = dirClusters
  .filter((c) => !c.surfaced && c.forming)
  .sort((a, b) => b.n_articles - a.n_articles);

// Synthetic sparkline for forming clusters: flat silence then recent onset at
// the right edge, using dormant color — purely illustrative, no real series.
const formingSpark = [...Array(34).fill(0), 0.2, 0.4, 0.5, 0.7, 0.9, 1.2, 1.6, 2.0, 2.5, 3.0];
const formingEntry = (c: (typeof formingClusters)[number]) =>
  ({
    cluster_id: c.cluster_id,
    label: c.label,
    label_human: c.label_human,
    n_articles: c.n_articles,
    date_range: c.date_range,
    top_terms: c.terms ?? [],
    in_scope: true,
  }) as unknown as IndexEntry;
// Press heating (ADR-074): computed at build time over the same quarterly
// window as corpus heating, from each narrative's shipped Media Cloud ratio
// series. Strongest deviation first.
const pressHeat = index.narratives
  .map((e) => ({ e, heat: pressHeating(narrs.get(e.cluster_id)?.mediacloud, frontierMs) }))
  .filter((x) => x.heat !== null)
  .sort((a, b) => b.heat!.z - a.heat!.z);
const heating = pressHeat.map((x) => x.e);
// Badge sets so a card in either gallery shows both signals it carries.
const corpusHotIds = new Set(corpusHeat.map((x) => x.e.cluster_id));
const pressHotIds = new Set(heating.map((e) => e.cluster_id));
const sparks: Record<number, number[]> = Object.fromEntries(
  [...corpusHeat.map((x) => x.e), ...heating].map((e) => [
    e.cluster_id,
    spark(narrs.get(e.cluster_id)!.volume.values),
  ]),
);
---

<Base title="emerging" active="emerging">
  <h1 class="reveal">heating in the corpus</h1>
  <p class="lede reveal">
    narratives whose
    quarterly institutional volume sit more than
    {CORPUS_HEATING.kSigma}σ above its yearly baseline,
    strongest deviation first.
  </p>

  <div class="toolbar reveal">
    <input id="e-search" type="search" placeholder="filter by name or term…" />
    <label class="toggle"><input type="checkbox" id="e-growth" checked /> growth</label>
    <label class="toggle"><input type="checkbox" id="e-stable" checked /> stable</label>
    <label class="toggle"><input type="checkbox" id="e-decay" checked /> decay</label>
    <label class="toggle"><input type="checkbox" id="e-dormant" checked /> dormant</label>
    {hasInScope && (
      <label class="toggle scope"><input type="checkbox" id="e-scope" checked /> macro scope only</label>
    )}
  </div>

  <div class="grid reveal" id="e-gallery">
    {corpusHeat.map(({ e }) => (
      <div class="card-wrap" data-label={(displayName(e) + " " + e.label).toLowerCase()}
        data-terms={e.top_terms.join(" ").toLowerCase()}
        data-stage={e.stage}
        data-scope={e.in_scope ? "in" : "out"}>
        <NarrativeCard entry={e} spark={sparks[e.cluster_id]}
          corpusHot={corpusHotIds.has(e.cluster_id)} pressHot={pressHotIds.has(e.cluster_id)} />
      </div>
    ))}
  </div>
  <p id="e-empty" class={`muted${corpusHeat.length ? " hidden" : ""}`}>
    {corpusHeat.length ? "no narratives match that filter." : "none right now."}
  </p>

  <section class="heating reveal">
    <h1>heating in the press</h1>
    <p class="lede">
      narratives whose quarterly press attention sits more
      than {PRESS_HEATING.kSigma}σ above its yearly baseline, strongest deviation first.
    </p>

    <div class="toolbar">
      <input id="h-search" type="search" placeholder="filter by name or term…" />
      <label class="toggle"><input type="checkbox" id="h-growth" checked /> growth</label>
      <label class="toggle"><input type="checkbox" id="h-stable" checked /> stable</label>
      <label class="toggle"><input type="checkbox" id="h-decay" checked /> decay</label>
      <label class="toggle"><input type="checkbox" id="h-dormant" checked /> dormant</label>
      {hasInScope && (
        <label class="toggle scope"><input type="checkbox" id="h-scope" checked /> macro scope only</label>
      )}
    </div>

    <div class="grid" id="h-gallery">
      {heating.map((e) => (
        <div class="card-wrap" data-label={(displayName(e) + " " + e.label).toLowerCase()}
          data-terms={e.top_terms.join(" ").toLowerCase()}
          data-stage={e.stage}
          data-scope={e.in_scope ? "in" : "out"}>
          <NarrativeCard entry={e} spark={sparks[e.cluster_id]}
            corpusHot={corpusHotIds.has(e.cluster_id)} pressHot={pressHotIds.has(e.cluster_id)} />
        </div>
      ))}
    </div>
    <p id="h-empty" class={`muted${heating.length ? " hidden" : ""}`}>
      {heating.length ? "no narratives match that filter." : "none right now."}
    </p>
  </section>

  <section class="heating reveal">
    <h1>forming</h1>
    <p class="lede">
      narratives with a recent onset yet not meeting the {floor}-article threshold for a full
      narrative page, most substantial first.
    </p>
    <div class="grid">
      {formingClusters.length > 0
        ? formingClusters.map((c) => (
            <NarrativeCard entry={formingEntry(c)} linked={false}
              spark={formingSpark} sparkColor={STAGE_COLOR.dormant} forming={true} />
          ))
        : <p class="muted">none right now.</p>
      }
    </div>
  </section>

  <script>
    import { setupCatalog } from "@lib/catalog";

    // Both sections carry the same filter bar as the narratives catalog; wire
    // each to its own controls by id prefix. The lists are short (a heating
    // signal fires on a handful of narratives), so no pager — every match shows.
    function wire(prefix) {
      const $ = (id) => document.getElementById(`${prefix}-${id}`);
      const search = $("search");
      const gallery = $("gallery");
      if (!search || !gallery) return;
      const flags = {
        growth: $("growth"),
        stable: $("stable"),
        decay: $("decay"),
        dormant: $("dormant"),
      };
      const scope = $("scope");
      const catalog = setupCatalog({
        cards: [...gallery.querySelectorAll(".card-wrap")],
        empty: $("empty"),
        pageSize: 500,
        matches(c) {
          const q = (search.value || "").trim().toLowerCase();
          const anyChecked = Object.values(flags).some((f) => f?.checked);
          const okText = !q || c.dataset.label.includes(q) || c.dataset.terms.includes(q);
          // cards without a stage (sub-floor clusters) pass the stage filter
          const okCat = !anyChecked || !c.dataset.stage || flags[c.dataset.stage]?.checked;
          const okScope = !scope?.checked || c.dataset.scope === "in";
          return okText && okCat && okScope;
        },
      });
      [search, ...Object.values(flags), scope].forEach((el) =>
        el?.addEventListener("input", () => catalog.refresh()),
      );
    }
    wire("e");
    wire("h");
  </script>
</Base>

<style>
  .toolbar {
    display: flex; gap: 1.2rem; flex-wrap: wrap; align-items: center;
    margin: 1.4rem 0 0.6rem; padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .toolbar input[type="search"] {
    flex: 1; min-width: 220px; padding: 0.55rem 0.2rem;
    border: none; border-bottom: 1px solid var(--line);
    background: transparent; font: inherit; color: var(--ink);
  }
  .toolbar input[type="search"]:focus {
    outline: none; border-bottom-color: var(--accent);
  }
  .heating {
    margin-top: var(--space-section); padding-top: var(--space-section);
    border-top: 1px solid var(--line);
  }
  .heating h1 { margin: 0.2rem 0 0.4rem; }
  .heating .lede { margin-bottom: 0.2rem; }
  .footnote { font-size: var(--fs-meta); margin-top: 1rem; }
</style>
