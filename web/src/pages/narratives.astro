---
import Base from "../layouts/Base.astro";
import NarrativeCard from "@components/NarrativeCard.astro";
import { loadIndex, loadNarrative, displayName } from "@lib/data";

const index = loadIndex();
const entries = index.narratives;

// The educational default foregrounds in-scope macro narratives (JEL E/F/G/H).
// Out-of-scope clusters are kept and reachable via the "macro scope only" toggle
// (ADR-046 — shown flagged, never dropped). The toggle defaults on only when the
// data actually carries a scope distinction, so a run where nothing is flagged
// in-scope still renders the full catalog instead of an empty page.
const hasInScope = entries.some((e) => e.in_scope);

// downsample each narrative's volume to a small sparkline at build time
function spark(values: number[], n = 44): number[] {
  if (values.length <= n) return values;
  const out: number[] = [];
  const step = values.length / n;
  for (let i = 0; i < n; i++) {
    const a = Math.floor(i * step);
    const b = Math.floor((i + 1) * step);
    const slice = values.slice(a, Math.max(a + 1, b));
    out.push(slice.reduce((s, v) => s + v, 0) / slice.length);
  }
  return out;
}
const sparks: Record<number, number[]> = Object.fromEntries(
  entries.map((e) => [e.cluster_id, spark(loadNarrative(e.cluster_id).volume.values)]),
);
---

<Base title="narratives" active="narratives">
  <p class="eyebrow reveal">the catalog</p>
  <h1 class="reveal">all narratives</h1>
  <p class="lede reveal">
    every cluster of writing the corpus found, in-scope macro narratives first.
    filter by name, term, stage, or scope.
  </p>

  <div class="toolbar reveal">
    <input id="search" type="search" placeholder="filter by name or term…" />
    <label class="toggle"><input type="checkbox" id="f-growth" checked /> growth</label>
    <label class="toggle"><input type="checkbox" id="f-stable" checked /> stable</label>
    <label class="toggle"><input type="checkbox" id="f-decay" checked /> decay</label>
    <label class="toggle"><input type="checkbox" id="f-dormant" checked /> dormant</label>
    {hasInScope && (
      <label class="toggle scope"><input type="checkbox" id="f-scope" checked /> macro scope only</label>
    )}
  </div>

  <div class="grid reveal" id="gallery">
    {entries.map((e) => (
      <div class="card-wrap" data-label={(displayName(e) + " " + e.label).toLowerCase()}
        data-terms={e.top_terms.join(" ").toLowerCase()}
        data-stage={e.stage}
        data-scope={e.in_scope ? "in" : "out"}>
        <NarrativeCard entry={e} spark={sparks[e.cluster_id]} />
      </div>
    ))}
  </div>
  <p id="empty" class="muted hidden">no narratives match that filter.</p>
  <nav id="pager" class="pager" aria-label="catalog pages"></nav>

  <script>
    import { setupCatalog } from "@lib/catalog";
    const search = document.getElementById("search");
    const flags = {
      growth: document.getElementById("f-growth"),
      stable: document.getElementById("f-stable"),
      decay: document.getElementById("f-decay"),
      dormant: document.getElementById("f-dormant"),
    };
    // scope facet is rendered only when the data carries a scope distinction.
    const scope = document.getElementById("f-scope");
    const catalog = setupCatalog({
      cards: [...document.querySelectorAll(".card-wrap")],
      empty: document.getElementById("empty"),
      pager: document.getElementById("pager"),
      scrollTo: document.getElementById("gallery"),
      matches(c) {
        const q = (search.value || "").trim().toLowerCase();
        // each stage checkbox is an independent facet, unioned together. with
        // nothing checked we treat it as no filter rather than hiding all.
        const anyChecked = Object.values(flags).some((f) => f.checked);
        const okText = !q || c.dataset.label.includes(q) || c.dataset.terms.includes(q);
        const okCat = !anyChecked || flags[c.dataset.stage]?.checked;
        const okScope = !scope?.checked || c.dataset.scope === "in";
        return okText && okCat && okScope;
      },
    });
    [search, ...Object.values(flags), scope].forEach((el) =>
      el?.addEventListener("input", () => catalog.refresh()),
    );
  </script>
</Base>

<style>
  .toolbar {
    display: flex; gap: 1.2rem; flex-wrap: wrap; align-items: center;
    margin: 1.4rem 0 0.6rem; padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .toolbar input[type="search"] {
    flex: 1; min-width: 220px; padding: 0.55rem 0.2rem;
    border: none; border-bottom: 1px solid var(--line);
    background: transparent; font: inherit; color: var(--ink);
  }
  .toolbar input[type="search"]:focus {
    outline: none; border-bottom-color: var(--accent);
  }
</style>
