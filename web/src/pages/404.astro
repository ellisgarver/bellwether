---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="not found">
  <h1 class="reveal">404 · page not found</h1>
  <p class="lede reveal">
    nothing is charted at this address — the page may have moved with a weekly
    rebuild, or never existed. try
    <a href={`${base}/narratives`}>the narrative catalog</a>, or head back
    <a href={`${base}/`}>home</a>.
  </p>
</Base>
