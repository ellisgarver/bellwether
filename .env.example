# Copy this to .env and fill in your values. NEVER commit .env.

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
# Used by the validation layer for macro indicator correlations.
FRED_API_KEY=

# GovInfo API key — free at https://api.govinfo.gov/signup/
# Required by CEAIngestor (ADR-020) to fetch the Economic Report of the
# President from the GPO ERP collection. DEMO_KEY fallback (30 req/hr) is
# only sufficient for integration tests; a real key (1000 req/hr) is
# required for the full ingest.
GOVINFO_API_KEY=

# Media Cloud API key — free academic access at mediacloud.org
# Required for both Layer 1B (premium-press dynamics, ADR-016) and
# Layer 2 (broad-press detection).
MEDIACLOUD_API_KEY=

# WRDS credentials — DEPRECATED by ADR-016 (2026-05-18).
# The RavenPack-via-WRDS dynamics layer was abandoned in favor of Media
# Cloud Premium. These variables are retained here so old `.env` files
# don't error, but they are not consumed by any active code path.
# WRDS_USERNAME=
# WRDS_PASSWORD=

# Optional: override default device for embedding
# Values: auto | cuda | cuda:0 | cpu | mps
MND_EMBEDDING_DEVICE=auto

# Optional: override max_seq_len for the active embedding model.
# Overrides config.yaml.embedding.<role>.max_seq_len at load time. Required on
# Apple Silicon MPS for Qwen3-Embedding-0.6B (set to 512 — ADR-006) to avoid
# OOM on the full attention matrix. Unset on RCC (CUDA) — config default applies.
MND_MAX_SEQ_LEN=

# Optional: override config file path
MND_CONFIG_PATH=config/config.yaml

# Required on any machine without TensorFlow installed (the default for this
# project). Prevents transformers from attempting TF-specific imports. See ADR-006.
USE_TF=0

# Required: tell Keras 3 to use the PyTorch backend instead of TensorFlow.
KERAS_BACKEND=torch
