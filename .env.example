# Copy this to .env and fill in your values. NEVER commit .env.

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ProQuest TDM Studio dataset ID (for paywalled-source ingestion).
# Set this to the dataset ID shown in the TDM Studio web UI after you create
# and build your dataset. The export script (src/mnd/ingestion/proquest.py)
# runs INSIDE TDM Studio's Jupyter environment and writes a JSONL file you
# then download and place in data/raw/articles/.
# See docs/proquest_tdm_setup.md for the full workflow.
PROQUEST_DATASET_ID=

# Hugging Face token — only required for gated models.
# Qwen3-Embedding-0.6B is OPEN under Apache 2.0 — token NOT required.
HF_TOKEN=

# Optional: override default device for embedding
# Values: auto | cuda | cuda:0 | cpu | mps
MND_EMBEDDING_DEVICE=auto

# Optional: override max_seq_len for the primary embedding model.
# config.yaml defaults to 32768 (for RCC/CUDA). Set to 512 on MacBook Air (MPS)
# to avoid OOM on Qwen3-Embedding-0.6B. See ADR-006.
# MacBook Air .env: MND_MAX_SEQ_LEN=512
MND_MAX_SEQ_LEN=

# Optional: NewsAPI key — required for Phase 6 live updates (Tier 2 wire coverage).
# Free tier: 100 requests/day. Sign up at newsapi.org.
NEWS_API_KEY=

# Optional: override config file path
MND_CONFIG_PATH=config/config.yaml

# Required on any machine without TensorFlow installed (the default for this
# project). Prevents transformers from attempting TF-specific imports.
# See ADR-006.
USE_TF=0

# Required: tell Keras 3 to use the PyTorch backend instead of TensorFlow.
# Without this, importing sentence_transformers on a machine with Keras 3
# raises a compatibility error. TensorFlow is NOT installed in this project.
KERAS_BACKEND=torch
